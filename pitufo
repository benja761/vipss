-- preview character clone
local function buildPreviewCharacter()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local previewModel = Instance.new("Model")
	previewModel.Name = "PreviewRig"
	previewModel.Parent = viewport

	for _, obj in ipairs(character:GetChildren()) do
		if obj:IsA("BasePart") or obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("BodyColors") or obj:IsA("CharacterMesh") then
			local clone = obj:Clone()
			clone.Parent = previewModel
		end
	end

	local cam = viewport.CurrentCamera
	cam.FieldOfView = 32

	local rootPart = previewModel:FindFirstChild("HumanoidRootPart") or previewModel:FindFirstChild("UpperTorso") or previewModel:FindFirstChild("Torso")
	if rootPart and rootPart:IsA("BasePart") then
		previewModel:PivotTo(CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(180), 0))
		cam.CFrame = CFrame.new(Vector3.new(0, 1.4, 7), Vector3.new(0, 1.2, 0))
	end

	local light = Instance.new("PointLight")
	light.Range = 16
	light.Brightness = 2
	light.Color = Color3.fromRGB(255, 235, 235)
	light.Parent = cam
end

