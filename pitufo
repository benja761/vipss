local function tween(obj: Instance, info: TweenInfo, props: {[string]: any})
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function makeCorner(obj: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
	return c
end

local function makeStroke(obj: Instance, color: Color3, thickness: number, transparency: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj
	return s
end

local function makePadding(obj: Instance, l: number, r: number, t: number, b: number)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, l)
	p.PaddingRight = UDim.new(0, r)
	p.PaddingTop = UDim.new(0, t)
	p.PaddingBottom = UDim.new(0, b)
	p.Parent = obj
	return p
end

local function addGradient(obj: Instance, c1: Color3, c2: Color3, rot: number)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, c1),
		ColorSequenceKeypoint.new(1, c2),
	})
	g.Rotation = rot
	g.Parent = obj
	return g
end

local function addList(parent: Instance, pad: number, sort: Enum.SortOrder?)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, pad)
	list.SortOrder = sort or Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function addAspect(parent: Instance, ratio: number)
	local a = Instance.new("UIAspectRatioConstraint")
	a.AspectRatio = ratio
	a.Parent = parent
	return a
end

local function addTextureOverlay(parent: Instance, image: string, transparency: number)
	local tex = Instance.new("ImageLabel")
	tex.Name = "Texture"
	tex.BackgroundTransparency = 1
	tex.Size = UDim2.fromScale(1, 1)
	tex.Image = image
	tex.ImageTransparency = transparency
	tex.ScaleType = Enum.ScaleType.Crop
	tex.ZIndex = parent.ZIndex + 1
	tex.Parent = parent
	makeCorner(tex, 10)
	return tex
end

