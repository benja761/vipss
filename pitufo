local function createToggle(parent, text, default, onChanged)
    local row = createFrame(parent, UDim2.new(1, 0, 0, 40), UDim2.new(), Theme.Soft, 8, 10)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.fromOffset(12, 0)
    label.Size = UDim2.new(1, -72, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = text
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextColor3 = Theme.Text
    label.ZIndex = 9
    label.Parent = row
    
    local pill = Instance.new("Frame")
    pill.AnchorPoint = Vector2.new(1, 0.5)
    pill.Position = UDim2.new(1, -10, 0.5, 0)
    pill.Size = UDim2.fromOffset(42, 22)
    pill.BackgroundColor3 = default and Theme.Accent or Color3.fromRGB(60, 63, 78)
    pill.ZIndex = 9
    pill.Parent = row
    makeCorner(pill, 11)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.fromOffset(16, 16)
    knob.Position = default and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)
    knob.BackgroundColor3 = Theme.White
    knob.ZIndex = 10
    knob.Parent = pill
    makeCorner(knob, 8)
    
    local state = default
    table.insert(activeTogglePills, {Pill = pill, GetState = function() return state end})
    
    local function setState(v)
        state = v
        tween(pill, TweenInfo.new(0.15), {BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(60, 63, 78)})
        tween(knob, TweenInfo.new(0.15), {Position = state and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)})
        if onChanged then onChanged(state) end
    end
    
    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            setState(not state)
            playUISound("rbxassetid://9118828561", 0.16, state and 1.06 or 0.96)
        end
    end)
    return row, setState
end

local function createSlider(parent, text, min, max, default, onChanged)
    local row = createFrame(parent, UDim2.new(1, 0, 0, 54), UDim2.new(), Theme.Soft, 8, 10)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
