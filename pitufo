local function tween(obj, info, props) local tw = TweenService:Create(obj, info, props) tw:Play() return tw end
local function makeCorner(obj, radius) local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, radius) c.Parent = obj return c end
local function makeStroke(obj, color, thickness) local s = Instance.new("UIStroke") s.Color = color s.Thickness = thickness s.Parent = obj return s end
local function addList(parent, padding) local list = Instance.new("UIListLayout") list.Padding = UDim.new(0, padding) list.SortOrder = Enum.SortOrder.LayoutOrder list.Parent = parent return list end
local function createFrame(parent, size, pos, color, z, radius) local frame = Instance.new("Frame") frame.Size = size frame.Position = pos frame.BackgroundColor3 = color frame.BorderSizePixel = 0 frame.ZIndex = z frame.Parent = parent makeCorner(frame, radius) makeStroke(frame, Theme.Stroke, 1) return frame end
local function addTextureOverlay(parent, transparency) local tex = Instance.new("ImageLabel") tex.Name = "TextureOverlay" tex.BackgroundTransparency = 1 tex.Size = UDim2.fromScale(1,1) tex.Image = "rbxassetid://9968344105" tex.ImageTransparency = transparency tex.ScaleType = Enum.ScaleType.Crop tex.ZIndex = parent.ZIndex + 1 tex.Parent = parent makeCorner(tex, 16) return tex end
local function accentRGBString(color) return string.format("%d,%d,%d", math.floor(color.R*255+0.5), math.floor(color.G*255+0.5), math.floor(color.B*255+0.5)) end
local function registerAccentObject(obj, prop, useDark) table.insert(liveAccentObjects, {Obj=obj, Prop=prop, Dark=useDark==true}) end
local function registerGradient(g) table.insert(gradientObjects, g) end
local function registerDynamicAccentUpdater(fn) table.insert(dynamicAccentUpdaters, fn) end
local function playUISound(id, volume, speed) if not State.SoundsEnabled then return end local s = Instance.new("Sound") s.SoundId = id s.Volume = volume s.PlaybackSpeed = speed or 1 s.Parent = game:GetService("SoundService") s:Play() s.Ended:Connect(function() s:Destroy() end) end

