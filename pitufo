
repeat task.wait() until game:IsLoaded()

local parent = (gethui and gethui()) or game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- BORRAR ANTERIOR
local old = parent:FindFirstChild("PITUFO_SPAM_REAL")
if old then old:Destroy() end

local gui = Instance.new("ScreenGui")
gui.Name = "PITUFO_SPAM_REAL"
gui.Parent = parent
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true

-- FUNCION RGB
local function rgb(t)
	return Color3.fromRGB(
		math.floor(math.sin(t)*127+128),
		math.floor(math.sin(t+2)*127+128),
		math.floor(math.sin(t+4)*127+128)
	)
end

-- SPAM REAL (MUCHO MÁS AGRESIVO)
task.spawn(function()
	while gui.Parent do
		for i = 1, 40 do -- MUCHOS por ciclo
			
			local txt = Instance.new("TextLabel")
			txt.Parent = gui
			txt.BackgroundTransparency = 1
			txt.Text = "ME QUERIAS ESTAFAR PITUFO?"
			txt.Font = Enum.Font.GothamBlack
			txt.TextScaled = true
			
			-- tamaño random grande
			local size = math.random(80, 250)
			txt.Size = UDim2.new(0, size*4, 0, size)

			-- posicion random TODA pantalla
			txt.Position = UDim2.new(
				math.random(),
				0,
				math.random(),
				0
			)

			-- rotacion
			txt.Rotation = math.random(-45, 45)

			-- color RGB
			txt.TextColor3 = rgb(tick())

			-- desaparición rápida
			task.delay(0.3, function()
				if txt then txt:Destroy() end
			end)
		end
		
		task.wait() -- LO MÁS RÁPIDO POSIBLE
	end
end)

-- FLASH CONSTANTE (pantallazos)
task.spawn(function()
	while gui.Parent do
		local flash = Instance.new("Frame")
		flash.Parent = gui
		flash.Size = UDim2.new(1,0,1,0)
		flash.BackgroundColor3 = rgb(tick())
		flash.BackgroundTransparency = 0.85
		
		task.delay(0.05, function()
			if flash then flash:Destroy() end
		end)
		
		task.wait(0.05)
	end
end)

-- TEXTO CENTRAL LOCO (SIEMPRE VISIBLE)
local center = Instance.new("TextLabel")
center.Parent = gui
center.Size = UDim2.new(0, 1000, 0, 250)
center.Position = UDim2.new(0.5, -500, 0.5, -125)
center.BackgroundTransparency = 1
center.Text = "ME QUERIAS ESTAFAR PITUFO?"
center.TextScaled = true
center.Font = Enum.Font.GothamBlack

RunService.RenderStepped:Connect(function()
	center.TextColor3 = rgb(tick())
	center.Rotation = math.sin(tick()*10)*10
end)
