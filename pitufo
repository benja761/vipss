end

local function createKeybindPicker(parent: Instance, text: string, defaultKey: Enum.KeyCode, prompt: string, onChanged: ((Enum.KeyCode) -> ())?)
	local row = createFrame(parent, UDim2.new(1, 0, 0, 40), UDim2.new(), Theme.Soft, 8, 10)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.fromOffset(12, 0)
	label.Size = UDim2.new(0.56, 0, 1, 0)
	label.Font = Enum.Font.GothamMedium
	label.Text = text
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Theme.Text
	label.ZIndex = 9
	label.Parent = row

	local value = Instance.new("TextLabel")
	value.BackgroundTransparency = 1
	value.AnchorPoint = Vector2.new(1, 0)
	value.Position = UDim2.new(1, -12, 0, 0)
	value.Size = UDim2.new(0.34, 0, 1, 0)
	value.Font = Enum.Font.GothamSemibold
	value.Text = defaultKey.Name
	value.TextSize = 12
	value.TextXAlignment = Enum.TextXAlignment.Right
	value.TextColor3 = Theme.SubText
	value.ZIndex = 9
	value.Parent = row

	local waiting = false

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and not State.WaitingForKeybind then
			waiting = true
			State.WaitingForKeybind = true
			value.Text = "Press..."
			value.TextColor3 = Theme.Accent
			notify("Keybind", prompt, 2.2)
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp or not waiting then
			return
		end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
			waiting = false
			State.WaitingForKeybind = false
			value.Text = input.KeyCode.Name
			value.TextColor3 = Theme.SubText
			playUISound("rbxassetid://9118823103", 0.2, 1.02)
			if onChanged then
				onChanged(input.KeyCode)
			end
		end
	end)

	return row, value
end

