local function updatePageButtons()
	for name, btn in pairs(pageButtons) do
		local active = name == currentPage
		local lbl = btn:FindFirstChildOfClass("TextLabel")
		tween(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = active and Theme.AccentDark or Theme.Soft
		})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {
				TextColor3 = active and Theme.Text or Theme.SubText
			})
		end
	end
end

local function updateSubButtons()
	for name, btn in pairs(subTabButtons) do
		local active = name == currentSub
		local lbl = btn:FindFirstChildOfClass("TextLabel")
		tween(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = active and Theme.AccentDark or Theme.Soft
		})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {
				TextColor3 = active and Theme.Text or Theme.SubText
			})
		end
	end
end

local function applySearch(query: string)
	query = string.lower(query)

	local pageItems = controlsByPage[currentPage] or {}
	for _, item in ipairs(pageItems) do
		local visibleBySub = item.Sub == currentSub
		local visibleByText = (query == "") or (string.find(item.Text, query, 1, true) ~= nil)
		item.Row.Visible = visibleBySub and visibleByText
	end
end

local function rebuildSubTabs(pageName: string)
	for _, child in ipairs(subTabsBar:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end

	table.clear(subTabButtons)
	local items = subTabsByPage[pageName] or {"Overview"}
	currentSub = items[1]

	for _, tabName in ipairs(items) do
		subTabButtons[tabName] = makeTabButton(subTabsBar, tabName, 104, function()
			currentSub = tabName
			updateSubButtons()
			applySearch(searchBox.Text)
		end)
	end

	updateSubButtons()
	applySearch(searchBox.Text)
end

local function showPage(name: string)
	currentPage = name
	for pageName, page in pairs(pages) do
		page.Visible = pageName == name
	end
	rebuildSubTabs(name)
	updatePageButtons()
end

