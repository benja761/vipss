-- tab creation
local function makeTabButton(parent: Instance, text: string, width: number, onClick: ()->())
	local btn = Instance.new("TextButton")
	btn.AutoButtonColor = false
	btn.Size = UDim2.fromOffset(width, 32)
	btn.BackgroundColor3 = Theme.Soft
	btn.Text = ""
	btn.ZIndex = 11
	btn.Parent = parent
	makeCorner(btn, 9)
	makeStroke(btn, Theme.Stroke, 1)

	local lbl = Instance.new("TextLabel")
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.fromScale(1,1)
	lbl.Font = Enum.Font.GothamSemibold
	lbl.Text = text
	lbl.TextSize = 13
	lbl.TextColor3 = Theme.SubText
	lbl.ZIndex = 12
	lbl.Parent = btn

	btn.MouseEnter:Connect(function()
		tween(btn, TweenInfo.new(0.14), {BackgroundColor3 = Color3.fromRGB(38,38,46)})
	end)
	btn.MouseLeave:Connect(function()
		if currentPage ~= text and currentSub ~= text then
			tween(btn, TweenInfo.new(0.14), {BackgroundColor3 = Theme.Soft})
		end
	end)
	btn.MouseButton1Click:Connect(onClick)

	return btn, lbl
end

local function updatePageButtonState()
	for name, btn in pairs(pageButtons) do
		local active = name == currentPage
		local lbl = btn:FindFirstChildOfClass("TextLabel")
		tween(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = active and Theme.Accent2 or Theme.Soft
		})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {
				TextColor3 = active and Theme.Text or Theme.SubText
			})
		end
	end
end

local function updateSubButtonState()
	for name, btn in pairs(subTabButtons) do
		local active = name == currentSub
		local lbl = btn:FindFirstChildOfClass("TextLabel")
		tween(btn, TweenInfo.new(0.15), {
			BackgroundColor3 = active and Theme.Accent2 or Theme.Soft
		})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {
				TextColor3 = active and Theme.Text or Theme.SubText
			})
		end
	end
end

local function showPage(name: string)
	currentPage = name
	for pageName, page in pairs(pages) do
		page.Visible = pageName == name
	end
	updatePageButtonState()
end

local defaultSubTabs = {"Overview", "Panels", "Style"}

local function rebuildSubTabs()
	for _, child in ipairs(subTabsBar:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
