local function tween(obj: Instance, info: TweenInfo, props: {[string]: any})
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function makeCorner(obj: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
	return c
end

local function makeStroke(obj: Instance, color: Color3, thickness: number, transparency: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj
	return s
end

local function addList(parent: Instance, pad: number)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, pad)
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function addTextureOverlay(parent: Instance, transparency: number)
	local tex = Instance.new("ImageLabel")
	tex.Name = "TextureOverlay"
	tex.BackgroundTransparency = 1
	tex.Size = UDim2.fromScale(1, 1)
	tex.Image = "rbxassetid://9968344105"
	tex.ImageTransparency = transparency
	tex.ScaleType = Enum.ScaleType.Crop
	tex.ZIndex = parent.ZIndex + 1
	tex.Parent = parent
	makeCorner(tex, 12)
	table.insert(textureOverlays, tex)
	return tex
end

local function registerAccentObject(obj: Instance, prop: string, dark: boolean?)
	table.insert(liveAccentObjects, {
		Obj = obj,
		Prop = prop,
		Dark = dark == true,
	})
end

local function registerGradient(gradient: UIGradient)
	table.insert(buttonGradients, gradient)
end

local function registerAccentRichText(label: TextLabel, prefix: string, suffix: string?)
	table.insert(dynamicAccentRichTexts, {
		Label = label,
		Prefix = prefix,
		Suffix = suffix or "",
	})
end

local function createFrame(parent: Instance, size: UDim2, pos: UDim2, color: Color3, z: number, radius: number)
	local f = Instance.new("Frame")
	f.Size = size
	f.Position = pos
	f.BackgroundColor3 = color
	f.BorderSizePixel = 0
	f.ZIndex = z
	f.Parent = parent
	makeCorner(f, radius)
	makeStroke(f, Theme.Stroke, 1)
	return f
end

local function accentRGBString(color: Color3)
	return string.format("%d,%d,%d", math.floor(color.R * 255 + 0.5), math.floor(color.G * 255 + 0.5), math.floor(color.B * 255 + 0.5))
end

local function updateAccentTexts()
	local rgb = accentRGBString(Theme.Accent)
	for _, item in ipairs(dynamicAccentRichTexts) do
		if item.Label and item.Label.Parent then
			item.Label.Text = string.format("<font color='rgb(%s)'>%s</font>%s", rgb, item.Prefix, item.Suffix)
		end
	end
end

local function setAccentColor(color: Color3)
	Theme.Accent = color
	Theme.AccentDark = Color3.fromRGB(
		math.max(0, math.floor(color.R * 255) - 72),
		math.max(0, math.floor(color.G * 255) - 72),
		math.max(0, math.floor(color.B * 255) - 72)
	)

	for _, item in ipairs(liveAccentObjects) do
		local obj, prop = item.Obj, item.Prop
		if obj and obj.Parent then
			pcall(function()
				obj[prop] = item.Dark and Theme.AccentDark or Theme.Accent
			end)
		end
	end

	for _, grad in ipairs(buttonGradients) do
		if grad and grad.Parent then
			grad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Theme.Accent),
				ColorSequenceKeypoint.new(1, Theme.AccentDark),
			})
		end
	end

	updateAccentTexts()
end

local function setTextureVisible(state: boolean)
	State.TextureEnabled = state
	for _, tex in ipairs(textureOverlays) do
		if tex and tex.Parent then
			tex.Visible = state
		end
	end
end

local function playUISound(id: string, volume: number, pitch: number?)
	if not State.SoundsEnabled then
		return
	end
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume
	s.PlaybackSpeed = pitch or 1
	s.RollOffMaxDistance = 0
	s.Parent = SoundService
	s:Play()
	s.Ended:Connect(function()
		s:Destroy()
	end)
	task.delay(3, function()
		if s.Parent then
			s:Destroy()
		end
	end)
end

