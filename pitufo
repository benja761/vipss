local startPos = UDim2.new()

header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = UserInputService:GetMouseLocation()
		startPos = root.Position
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = UserInputService:GetMouseLocation() - dragStart
		root.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

-- search filtering
local function applySearch(query: string)
	query = string.lower(query)

	for _, obj in ipairs(allSearchTargets) do
		local parent = obj.Parent
		if parent and parent:IsA("GuiObject") then
			if query == "" then
				parent.Visible = true
			else
				local text = ""
				if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
					text = string.lower(obj.Text)
				end
				parent.Visible = string.find(text, query, 1, true) ~= nil
			end
		end
	end
end

searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	applySearch(searchBox.Text)
end)

-- open / close
local function setOpen(state: boolean)
	menuOpen = state
	tween(UIScaleRoot, TweenInfo.new(0.18), {Scale = state and 1 or 0.96})
	tween(main, TweenInfo.new(0.18), {BackgroundTransparency = state and 0 or 0.12})
	tween(glow, TweenInfo.new(0.18), {ImageTransparency = state and 0.35 or 0.6})
	tween(blur, TweenInfo.new(0.18), {Size = state and 14 or 0})
	bottomHolder.Visible = state
	previewCard.Visible = state
	pagesHolder.Visible = state
	header.Visible = state
	if not state then
		task.delay(0.18, function()
			if not menuOpen then
				main.Visible = false
			end
		end)
	else
		main.Visible = true
	end
end

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end

	if input.KeyCode == Enum.KeyCode.RightShift then
		if not menuOpen then
			main.Visible = true
		end
		setOpen(not menuOpen)
	end
end)

