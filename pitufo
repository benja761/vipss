local hsvH, hsvS, hsvV = 0, 0.84, 0.73

local function updateHSVVisuals()
	local hueColor = Color3.fromHSV(hsvH, 1, 1)
	satValFrame.BackgroundColor3 = hueColor
	svCursor.Position = UDim2.new(hsvS, 0, 1 - hsvV, 0)
	hueCursor.Position = UDim2.new(0.5, 0, hsvH, 0)

	local final = Color3.fromHSV(hsvH, hsvS, hsvV)
	previewFill.BackgroundColor3 = final
	rgbText.Text = string.format("RGB: %d, %d, %d", math.floor(final.R * 255 + 0.5), math.floor(final.G * 255 + 0.5), math.floor(final.B * 255 + 0.5))
end

local function openColorModal(state: boolean)
	if state then
		overlay.Visible = true
		colorModal.Visible = true
		tween(overlay, TweenInfo.new(0.16), {BackgroundTransparency = 0.28})
		playUISound("rbxassetid://9118823103", 0.2)
	else
		tween(overlay, TweenInfo.new(0.16), {BackgroundTransparency = 1})
		task.delay(0.18, function()
			overlay.Visible = false
			colorModal.Visible = false
		end)
	end
end

local svDragging = false
local hueDragging = false

local function updateSV(mousePos: Vector2)
	local alphaX = math.clamp((mousePos.X - satValFrame.AbsolutePosition.X) / satValFrame.AbsoluteSize.X, 0, 1)
	local alphaY = math.clamp((mousePos.Y - satValFrame.AbsolutePosition.Y) / satValFrame.AbsoluteSize.Y, 0, 1)
	hsvS = alphaX
	hsvV = 1 - alphaY
	updateHSVVisuals()
end

local function updateHue(mousePos: Vector2)
	local alphaY = math.clamp((mousePos.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
	hsvH = alphaY
	updateHSVVisuals()
end

