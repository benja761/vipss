    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and not State.WaitingForKeybind then
            waiting = true
            State.WaitingForKeybind = true
            value.Text = "Press..."
            value.TextColor3 = Theme.Accent
            notify("Keybind", prompt, 2.2)
        end
    end)
    
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp or not waiting then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
            waiting = false
            State.WaitingForKeybind = false
            value.Text = input.KeyCode.Name
            value.TextColor3 = Theme.SubText
            playUISound("rbxassetid://9118823103", 0.2, 1.02)
            if onChanged then onChanged(input.KeyCode) end
        end
    end)
    return row, value
end

