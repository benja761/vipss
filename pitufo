local function createPresetItem(name: string, color: Color3)
	local item = createFrame(presetsListWrap, UDim2.new(1, 0, 0, 44), UDim2.new(), Theme.Soft, 43, 10)

	local swatch = Instance.new("Frame")
	swatch.Position = UDim2.fromOffset(10, 10)
	swatch.Size = UDim2.fromOffset(24, 24)
	swatch.BackgroundColor3 = color
	swatch.ZIndex = 44
	swatch.Parent = item
	makeCorner(swatch, 7)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.fromOffset(46, 0)
	label.Size = UDim2.new(1, -56, 1, 0)
	label.Font = Enum.Font.GothamMedium
	label.Text = name
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Theme.Text
	label.ZIndex = 44
	label.Parent = item

	item.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			setAccentColor(color)
			if espSkeletonColorPreview then espSkeletonColorPreview.BackgroundColor3 = color end
			statTheme.Text = name
			notify("Colors", "Accent changed to " .. name, 2.7)
			playUISound("rbxassetid://9118823103", 0.22)
		end
	end)
end

