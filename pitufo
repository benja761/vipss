	label.Parent = row

	local pill = Instance.new("Frame")
	pill.AnchorPoint = Vector2.new(1, 0.5)
	pill.Position = UDim2.new(1, -10, 0.5, 0)
	pill.Size = UDim2.fromOffset(42, 22)
	pill.BackgroundColor3 = default and Theme.Accent or Color3.fromRGB(60, 63, 78)
	pill.ZIndex = 9
	pill.Parent = row
	makeCorner(pill, 11)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(16, 16)
	knob.Position = default and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)
	knob.BackgroundColor3 = Theme.White
	knob.ZIndex = 10
	knob.Parent = pill
	makeCorner(knob, 8)

	local state = default

	local function setState(v: boolean)
		state = v
		tween(pill, TweenInfo.new(0.15), {
			BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(60, 63, 78)
		})
		tween(knob, TweenInfo.new(0.15), {
			Position = state and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)
		})
		if onChanged then
			onChanged(state)
		end
	end

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			setState(not state)
			playUISound("rbxassetid://9118828561", 0.16, state and 1.08 or 0.96)
		end
	end)

	return row, setState
end

