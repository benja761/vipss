local function createDrawingsForPlayer(plr)
	if plr == LocalPlayer then return end
	local d = {
		BoxLines = {}, CornerLines = {}, SkeletonLines = {}, HealthLines = {}, Tracer = Drawing.new("Line"),
		NameText = Drawing.new("Text"), DistanceText = Drawing.new("Text")
	}
	
	-- Box
	for i = 1,4 do
		local l = Drawing.new("Line") l.Thickness = State.LineThickness l.Color = State.ESPColor d.BoxLines[i] = l
	end
	-- Corner
	for i = 1,8 do
		local l = Drawing.new("Line") l.Thickness = State.LineThickness l.Color = State.ESPColor d.CornerLines[i] = l
	end
	-- Skeleton
	for i = 1,#bonePairs do
		local l = Drawing.new("Line") l.Thickness = State.SkeletonThickness l.Color = State.ESPColor d.SkeletonLines[i] = l
	end
	-- Health Bar
	for i = 1,2 do d.HealthLines[i] = Drawing.new("Line") end
	
	d.NameText.Size = 15 d.NameText.Center = true d.NameText.Outline = true d.NameText.Color = Color3.new(1,1,1)
	d.DistanceText.Size = 13 d.DistanceText.Center = true d.DistanceText.Outline = true d.DistanceText.Color = Color3.new(1,1,1)
	
	drawings[plr] = d
end

