local aimConn
UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not State.AimEnabled or input.KeyCode ~= State.AimKey then return end
    
    if aimConn then aimConn:Disconnect() end
    aimConn = RunService.RenderStepped:Connect(function()
        local mouse = UserInputService:GetMouseLocation()
        local closest, dist = nil, State.FOVRadius + 10
        
        for _, plr in Players:GetPlayers() do
            if plr == LocalPlayer or not plr.Character or not plr.Character:FindFirstChild("Humanoid") or plr.Character.Humanoid.Health <= 0 then continue end
            if State.ESPTeamCheck and plr.Team == LocalPlayer.Team then continue end
            
            local part = plr.Character:FindFirstChild(State.TargetPart == "Chest" and "UpperTorso" or State.TargetPart) or plr.Character.Head
            if part then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - mouse).Magnitude
                    if d < dist then dist = d closest = part end
                end
            end
        end
        
        if closest then
            local targetPos = closest.Position + (closest.AssemblyLinearVelocity or Vector3.zero) * 0.035
            local targetCF = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, math.clamp(1 - State.AimSmooth/35, 0.08, 0.65))
        end
    end)
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == State.AimKey and aimConn then
        aimConn:Disconnect()
        aimConn = nil
    end
end)

