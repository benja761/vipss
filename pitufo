local function updatePageButtons()
	for name, button in pairs(pageButtons) do
		local active = name == currentPage
		local lbl = button:FindFirstChildOfClass("TextLabel")
		tween(button, TweenInfo.new(0.15), {
			BackgroundColor3 = active and Theme.AccentDark or Theme.Soft,
		})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {
				TextColor3 = active and Theme.Text or Theme.SubText,
			})
		end
	end
end

local function applySearch(query: string)
	query = string.lower(query)
	for _, item in ipairs(controlsByPage[currentPage] or {}) do
		item.Row.Visible = (query == "") or (string.find(item.Text, query, 1, true) ~= nil)
	end
end

local function showPage(name: string)
	currentPage = name
	for pageName, page in pairs(pages) do
		page.Visible = pageName == name
	end
	updatePageButtons()
	applySearch(searchBox.Text)
end

local function setAccentColor(color: Color3)
	Theme.Accent = color
	Theme.AccentDark = Color3.fromRGB(
		math.max(0, math.floor(color.R * 255 + 0.5) - 70),
		math.max(0, math.floor(color.G * 255 + 0.5) - 70),
		math.max(0, math.floor(color.B * 255 + 0.5) - 70)
	)

	for _, item in ipairs(liveAccentObjects) do
		if item.Obj and item.Obj.Parent then
			pcall(function()
				item.Obj[item.Prop] = item.Dark and Theme.AccentDark or Theme.Accent
			end)
		end
	end

	for _, item in ipairs(activeTogglePills) do
		if item.Pill and item.Pill.Parent and item.GetState() then
			item.Pill.BackgroundColor3 = Theme.Accent
		end
	end

	for _, gradient in ipairs(gradientObjects) do
		if gradient and gradient.Parent then
			gradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Theme.Accent),
				ColorSequenceKeypoint.new(1, Theme.AccentDark),
			})
		end
	end

	for _, updater in ipairs(dynamicAccentUpdaters) do
		updater()
	end

	updatePageButtons()
end

