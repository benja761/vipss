    local value = Instance.new("TextLabel")
    value.BackgroundTransparency = 1
    value.AnchorPoint = Vector2.new(1, 0)
    value.Position = UDim2.new(1, -12, 0, 6)
    value.Size = UDim2.fromOffset(62, 18)
    value.Font = Enum.Font.GothamSemibold
    value.Text = tostring(default)
    value.TextSize = 13
    value.TextXAlignment = Enum.TextXAlignment.Right
    value.TextColor3 = Theme.SubText
    value.ZIndex = 9
    value.Parent = row
    
    local bar = Instance.new("Frame")
    bar.Position = UDim2.fromOffset(12, 34)
    bar.Size = UDim2.new(1, -24, 0, 8)
    bar.BackgroundColor3 = Color3.fromRGB(52, 56, 73)
    bar.BorderSizePixel = 0
    bar.ZIndex = 9
    bar.Parent = row
    makeCorner(bar, 4)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel = 0
    fill.ZIndex = 10
    fill.Parent = bar
    makeCorner(fill, 4)
    registerAccentObject(fill, "BackgroundColor3")
    
    local knob = Instance.new("Frame")
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(fill.Size.X.Scale, 0, 0.5, 0)
    knob.Size = UDim2.fromOffset(14, 14)
    knob.BackgroundColor3 = Theme.White
    knob.ZIndex = 11
    knob.Parent = bar
    makeCorner(knob, 7)
    
    local dragging = false
    local function update(x)
        local alpha = math.clamp((x - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
        local valueNumber = math.floor(min + (max - min) * alpha + 0.5)
        fill.Size = UDim2.new(alpha, 0, 1, 0)
        knob.Position = UDim2.new(alpha, 0, 0.5, 0)
        value.Text = tostring(valueNumber)
        if onChanged then onChanged(valueNumber) end
    end
    
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(UserInputService:GetMouseLocation().X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(UserInputService:GetMouseLocation().X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    return row, value
end

