local function createKeybindPicker(parent: Instance, labelText: string, defaultKey: Enum.KeyCode, onChanged: ((Enum.KeyCode) -> ())?)
	local row = createFrame(parent, UDim2.new(1, 0, 0, 40), UDim2.new(), Theme.Soft, 8, 9)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.fromOffset(12, 0)
	label.Size = UDim2.new(0.55, 0, 1, 0)
	label.Font = Enum.Font.GothamMedium
	label.Text = labelText
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Theme.Text
	label.ZIndex = 9
	label.Parent = row

	local value = Instance.new("TextLabel")
	value.BackgroundTransparency = 1
	value.AnchorPoint = Vector2.new(1, 0)
	value.Position = UDim2.new(1, -12, 0, 0)
	value.Size = UDim2.new(0.35, 0, 1, 0)
	value.Font = Enum.Font.GothamSemibold
	value.Text = defaultKey.Name
	value.TextSize = 12
	value.TextXAlignment = Enum.TextXAlignment.Right
	value.TextColor3 = Theme.SubText
	value.ZIndex = 9
	value.Parent = row

	local waiting = false

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			waiting = true
			State.WaitingForKeybind = true
			value.Text = "Press..."
			value.TextColor3 = Theme.Accent
			notify("Settings", "Press a key to bind menu hide/show.", 2.4)
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp or not waiting then
			return
		end

		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
			waiting = false
			State.WaitingForKeybind = false
			value.Text = input.KeyCode.Name
			value.TextColor3 = Theme.SubText
			if onChanged then
				onChanged(input.KeyCode)
			end
			playUISound("rbxassetid://9118823103", 0.22, 1.0)
			notify("Settings", "Menu keybind changed to " .. input.KeyCode.Name, 2.6)
		end
	end)

	return row, value
end

