local function tween(obj: Instance, info: TweenInfo, props: {[string]: any})
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function makeCorner(obj: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
	return c
end

local function makeStroke(obj: Instance, color: Color3, thickness: number, transparency: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj
	return s
end

local function addList(parent: Instance, pad: number)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, pad)
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function addTextureOverlay(parent: Instance, transparency: number)
	local tex = Instance.new("ImageLabel")
	tex.BackgroundTransparency = 1
	tex.Size = UDim2.fromScale(1, 1)
	tex.Image = "rbxassetid://9968344105"
	tex.ImageTransparency = transparency
	tex.ScaleType = Enum.ScaleType.Crop
	tex.ZIndex = parent.ZIndex + 1
	tex.Parent = parent
	makeCorner(tex, 12)
	return tex
end

local function createFrame(parent: Instance, size: UDim2, pos: UDim2, color: Color3, z: number, radius: number)
	local f = Instance.new("Frame")
	f.Size = size
	f.Position = pos
	f.BackgroundColor3 = color
	f.BorderSizePixel = 0
	f.ZIndex = z
	f.Parent = parent
	makeCorner(f, radius)
	makeStroke(f, Theme.Stroke, 1)
	return f
end

local liveAccentObjects = {}

local function registerAccentObject(obj: Instance, prop: string)
	table.insert(liveAccentObjects, {Obj = obj, Prop = prop})
end

local function setAccentColor(color: Color3)
	Theme.Accent = color
	Theme.AccentDark = Color3.fromRGB(
		math.max(0, math.floor(color.R * 255) - 65),
		math.max(0, math.floor(color.G * 255) - 65),
		math.max(0, math.floor(color.B * 255) - 65)
	)
	for _, item in ipairs(liveAccentObjects) do
		local obj, prop = item.Obj, item.Prop
		if obj and obj.Parent then
			pcall(function()
				obj[prop] = color
			end)
		end
	end
end

