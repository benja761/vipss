	table.clear(subTabButtons)

	for _, name in ipairs(defaultSubTabs) do
		local b = makeTabButton(subTabsBar, name, 96, function()
			currentSub = name
			updateSubButtonState()
		end)
		subTabButtons[name] = b
	end
	updateSubButtonState()
end

