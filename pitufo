	accentGlow.BackgroundColor3 = Theme.Accent
	accentGlow.BorderSizePixel = 0
	accentGlow.ZIndex = 32
	accentGlow.Parent = card
	registerAccentObject(accentGlow, "BackgroundColor3")

	local glowLine = Instance.new("ImageLabel")
	glowLine.BackgroundTransparency = 1
	glowLine.Size = UDim2.fromOffset(26, 74)
	glowLine.Position = UDim2.fromOffset(-8, 0)
	glowLine.Image = "rbxassetid://5028857084"
	glowLine.ScaleType = Enum.ScaleType.Slice
	glowLine.SliceCenter = Rect.new(24, 24, 276, 276)
	glowLine.ImageTransparency = 0.55
	glowLine.ImageColor3 = Theme.Accent
	glowLine.ZIndex = 31
	glowLine.Parent = card
	registerAccentObject(glowLine, "ImageColor3")

	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Position = UDim2.fromOffset(18, 9)
	t.Size = UDim2.new(1, -28, 0, 20)
	t.Font = Enum.Font.GothamBold
	t.Text = titleText
	t.TextSize = 13
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextColor3 = Theme.Text
	t.ZIndex = 32
	t.Parent = card

	local b = Instance.new("TextLabel")
	b.BackgroundTransparency = 1
	b.Position = UDim2.fromOffset(18, 30)
	b.Size = UDim2.new(1, -28, 0, 28)
	b.Font = Enum.Font.Gotham
	b.Text = bodyText
	b.TextSize = 12
	b.TextWrapped = true
	b.TextXAlignment = Enum.TextXAlignment.Left
	b.TextYAlignment = Enum.TextYAlignment.Top
	b.TextColor3 = Theme.SubText
	b.ZIndex = 32
	b.Parent = card

	local barBack = Instance.new("Frame")
	barBack.Position = UDim2.fromOffset(18, 60)
	barBack.Size = UDim2.new(1, -36, 0, 4)
	barBack.BackgroundColor3 = Theme.Soft2
	barBack.BorderSizePixel = 0
	barBack.ZIndex = 32
	barBack.Parent = card
	makeCorner(barBack, 3)

	local barFill = Instance.new("Frame")
	barFill.Size = UDim2.fromScale(1, 1)
	barFill.BackgroundColor3 = Theme.Accent
	barFill.BorderSizePixel = 0
	barFill.ZIndex = 33
	barFill.Parent = barBack
	makeCorner(barFill, 3)
	registerAccentObject(barFill, "BackgroundColor3")

	card.Position = UDim2.fromOffset(36, 0)
	card.BackgroundTransparency = 1
	tween(card, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.fromOffset(0, 0),
		BackgroundTransparency = 0
	})
	tween(barFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.fromScale(0, 1)})

	task.delay(duration, function()
		if not card.Parent then return end
		tween(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Position = UDim2.fromOffset(40, 0),
			BackgroundTransparency = 1
		})
		task.wait(0.2)
		card:Destroy()
	end)
end

