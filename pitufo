        -- Vibración de cámara (Opcional, muy molesto)
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.CameraOffset = Vector3.new(math.random(-1,1), math.random(-1,1), math.random(-1,1))
        end
        
        i = i % #colors + 1
        task.wait(0.1) -- Velocidad de parpadeo (Muy rápido)
