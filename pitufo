		return
	end

	duration = duration or State.NotificationDuration

	local card = createFrame(notifHolder, UDim2.fromOffset(318, 74), UDim2.new(), Theme.BG2, 31, 12)
	addTextureOverlay(card, 0.96)

	local accentGlow = Instance.new("Frame")
