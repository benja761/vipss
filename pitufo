repeat task.wait() until game:IsLoaded()

local parent = (gethui and gethui()) or game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local old = parent:FindFirstChild("FULL_PITUFO_VISUAL")
if old then old:Destroy() end

local gui = Instance.new("ScreenGui")
gui.Name = "FULL_PITUFO_VISUAL"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true
gui.DisplayOrder = 999999
gui.Parent = parent

local function rgb(t)
	return Color3.fromRGB(
		math.floor(math.sin(t * 2) * 127 + 128),
		math.floor(math.sin(t * 2 + 2) * 127 + 128),
		math.floor(math.sin(t * 2 + 4) * 127 + 128)
	)
end

-- Fondo
local bg = Instance.new("Frame")
bg.Parent = gui
bg.Size = UDim2.new(1, 0, 1, 0)
bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
bg.BorderSizePixel = 0

-- Spam visual de fondo
task.spawn(function()
	while gui.Parent do
		for i = 1, 25 do
			local t = Instance.new("TextLabel")
			t.Parent = gui
			t.BackgroundTransparency = 1
			t.BorderSizePixel = 0
			t.Text = "ME QUERIAS ESTAFAR PITUFO?"
			t.Font = Enum.Font.GothamBlack
			t.TextScaled = true
			t.TextTransparency = 0.15
			t.Size = UDim2.new(0, math.random(350, 900), 0, math.random(60, 180))
			t.Position = UDim2.new(math.random(), -200, math.random(), -50)
			t.Rotation = math.random(-35, 35)
			t.TextColor3 = rgb(tick() + i)

			task.delay(0.35, function()
				if t and t.Parent then
					t:Destroy()
				end
			end)
		end
		task.wait(0.03)
	end
end)

-- Mensaje principal gigante
local main = Instance.new("TextLabel")
main.Parent = gui
main.BackgroundTransparency = 1
main.Size = UDim2.new(1, -40, 1, -40)
main.Position = UDim2.new(0, 20, 0, 20)
main.Text = "ME QUERIAS\nESTAFAR\nPITUFO?"
main.Font = Enum.Font.GothamBlack
main.TextScaled = true
main.TextWrapped = true
main.ZIndex = 10

local stroke = Instance.new("UIStroke")
stroke.Parent = main
stroke.Thickness = 4

-- Capas extra para tapar más la pantalla
local shadow1 = Instance.new("TextLabel")
shadow1.Parent = gui
shadow1.BackgroundTransparency = 1
shadow1.Size = main.Size
shadow1.Position = UDim2.new(0, 28, 0, 28)
shadow1.Text = main.Text
shadow1.Font = Enum.Font.GothamBlack
shadow1.TextScaled = true
shadow1.TextWrapped = true
shadow1.TextColor3 = Color3.fromRGB(255, 0, 0)
shadow1.TextTransparency = 0.45
shadow1.ZIndex = 8

local shadow2 = Instance.new("TextLabel")
shadow2.Parent = gui
shadow2.BackgroundTransparency = 1
shadow2.Size = main.Size
shadow2.Position = UDim2.new(0, 12, 0, 12)
shadow2.Text = main.Text
shadow2.Font = Enum.Font.GothamBlack
shadow2.TextScaled = true
shadow2.TextWrapped = true
shadow2.TextColor3 = Color3.fromRGB(255, 255, 255)
shadow2.TextTransparency = 0.2
shadow2.ZIndex = 9

RunService.RenderStepped:Connect(function()
	local t = tick()
	local c = rgb(t)
	bg.BackgroundColor3 = Color3.fromRGB(
		math.floor(20 + math.abs(math.sin(t * 3)) * 40),
		0,
		0
	)
	main.TextColor3 = c
	stroke.Color = Color3.fromRGB(255, 255, 255)
	main.Rotation = math.sin(t * 8) * 2
	shadow1.Rotation = math.sin(t * 6) * -3
	shadow2.Rotation = math.sin(t * 7) * 1.5
end)
