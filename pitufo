local function notify(titleText: string, bodyText: string, duration: number?)
	if not State.NotificationsEnabled then
		return
	end
	duration = duration or State.NotificationDuration

	local card = createFrame(notifHolder, UDim2.fromOffset(326, 76), UDim2.new(), Theme.BG2, 31, 12)
	addTextureOverlay(card, 0.965)

	local accent = Instance.new("Frame")
	accent.Size = UDim2.fromOffset(5, 76)
	accent.BackgroundColor3 = Theme.Accent
	accent.BorderSizePixel = 0
	accent.ZIndex = 32
	accent.Parent = card
	registerAccentObject(accent, "BackgroundColor3")

	local glow = Instance.new("ImageLabel")
	glow.BackgroundTransparency = 1
	glow.Size = UDim2.fromOffset(22, 76)
	glow.Position = UDim2.fromOffset(-7, 0)
	glow.Image = "rbxassetid://5028857084"
	glow.ScaleType = Enum.ScaleType.Slice
	glow.SliceCenter = Rect.new(24, 24, 276, 276)
	glow.ImageTransparency = 0.56
	glow.ImageColor3 = Theme.Accent
	glow.ZIndex = 31
	glow.Parent = card
	registerAccentObject(glow, "ImageColor3")

	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Position = UDim2.fromOffset(18, 10)
	t.Size = UDim2.new(1, -28, 0, 18)
	t.Font = Enum.Font.GothamBold
	t.Text = titleText
	t.TextSize = 13
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextColor3 = Theme.Text
	t.ZIndex = 32
	t.Parent = card

	local b = Instance.new("TextLabel")
	b.BackgroundTransparency = 1
	b.Position = UDim2.fromOffset(18, 30)
	b.Size = UDim2.new(1, -28, 0, 28)
	b.Font = Enum.Font.Gotham
	b.Text = bodyText
	b.TextSize = 12
	b.TextWrapped = true
	b.TextXAlignment = Enum.TextXAlignment.Left
	b.TextYAlignment = Enum.TextYAlignment.Top
	b.TextColor3 = Theme.SubText
	b.ZIndex = 32
	b.Parent = card

	local track = Instance.new("Frame")
	track.Position = UDim2.fromOffset(18, 62)
	track.Size = UDim2.new(1, -36, 0, 4)
	track.BackgroundColor3 = Theme.Soft2
	track.BorderSizePixel = 0
	track.ZIndex = 32
	track.Parent = card
	makeCorner(track, 3)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.fromScale(1, 1)
	fill.BackgroundColor3 = Theme.Accent
	fill.BorderSizePixel = 0
	fill.ZIndex = 33
	fill.Parent = track
	makeCorner(fill, 3)
	registerAccentObject(fill, "BackgroundColor3")

	card.Position = UDim2.fromOffset(28, 0)
	card.BackgroundTransparency = 1
	tween(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.fromOffset(0, 0),
		BackgroundTransparency = 0,
	})
	tween(fill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.fromScale(0, 1)})

	task.delay(duration, function()
		if not card.Parent then return end
		tween(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Position = UDim2.fromOffset(38, 0),
			BackgroundTransparency = 1,
		})
		task.wait(0.2)
		if card.Parent then
			card:Destroy()
		end
	end)
end

