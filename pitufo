-- ==================== ESP DRAWINGS ====================
local drawings = {}

local bonePairs = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}

local function createESP(plr)
    if plr == LocalPlayer then return end
    local d = {
        Box = {}, Corner = {}, Skeleton = {}, Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"), Distance = Drawing.new("Text"), HealthBar = {},
    }
    
    -- Box (4 lines)
    for i = 1,4 do
        local l = Drawing.new("Line")
        l.Thickness = State.LineThickness
        l.Color = State.ESPColor
        d.Box[i] = l
    end
    
    -- Corner (8 lines)
    for i = 1,8 do
        local l = Drawing.new("Line")
        l.Thickness = State.LineThickness
        l.Color = State.ESPColor
        d.Corner[i] = l
    end
    
    -- Skeleton
    for i = 1,#bonePairs do
        local l = Drawing.new("Line")
        l.Thickness = State.SkeletonThickness
        l.Color = State.ESPColor
        d.Skeleton[i] = l
    end
    
    -- Health Bar
    for i = 1,2 do
        local l = Drawing.new("Line")
        l.Thickness = 4
        d.HealthBar[i] = l
    end
    
    d.Name.Size = 15
    d.Name.Center = true
    d.Name.Outline = true
    d.Name.Color = Color3.new(1,1,1)
    
    d.Distance.Size = 13
    d.Distance.Center = true
    d.Distance.Outline = true
    d.Distance.Color = Color3.new(1,1,1)
    
    drawings[plr] = d
end

for _, p in Players:GetPlayers() do createESP(p) end
