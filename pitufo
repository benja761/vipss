-- XENO SCRIPT PRO VISUAL (PESADO PERO SEGURO)

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- BLUR EFECTO
local blur = Instance.new("BlurEffect")
blur.Size = 0
blur.Parent = Lighting

TweenService:Create(blur, TweenInfo.new(0.5), {Size = 25}):Play()

-- FRAME PRINCIPAL
local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.Size = UDim2.new(0, 500, 0, 160)
Frame.Position = UDim2.new(0.5, -250, 0.5, -80)
Frame.BackgroundColor3 = Color3.fromRGB(15,15,20)
Frame.BorderSizePixel = 0

-- GLOW
local UIStroke = Instance.new("UIStroke", Frame)
UIStroke.Thickness = 3
UIStroke.Color = Color3.fromRGB(255,0,0)

-- TEXTO
local TextLabel = Instance.new("TextLabel")
TextLabel.Parent = Frame
TextLabel.Size = UDim2.new(1,0,1,0)
TextLabel.BackgroundTransparency = 1
TextLabel.Text = "ME QUERIAS ESTAFAR PITUFO?"
TextLabel.TextScaled = true
TextLabel.Font = Enum.Font.GothamBlack
TextLabel.TextColor3 = Color3.fromRGB(255,255,255)

-- RGB ANIMADO
RunService.RenderStepped:Connect(function()
	local t = tick()
	local r = math.sin(t)*127+128
	local g = math.sin(t+2)*127+128
	local b = math.sin(t+4)*127+128
	
	UIStroke.Color = Color3.fromRGB(r,g,b)
	TextLabel.TextColor3 = Color3.fromRGB(r,g,b)
end)

-- PARTÍCULAS (FAKE VISUAL)
for i = 1, 30 do
	task.spawn(function()
		local dot = Instance.new("Frame")
		dot.Parent = Frame
		dot.Size = UDim2.new(0, 4, 0, 4)
		dot.BackgroundColor3 = Color3.fromRGB(255,0,0)
		dot.BorderSizePixel = 0
		
		while dot.Parent do
			dot.Position = UDim2.new(math.random(),0,1,0)
			
			local tween = TweenService:Create(dot, TweenInfo.new(1 + math.random()), {
				Position = UDim2.new(math.random(),0,0,0),
				BackgroundTransparency = 1
			})
			
			tween:Play()
			tween.Completed:Wait()
			
			dot.BackgroundTransparency = 0
		end
	end)
end

-- ANIMACIÓN POP
Frame.Size = UDim2.new(0, 0, 0, 0)
TweenService:Create(Frame, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
	Size = UDim2.new(0, 500, 0, 160)
}):Play()

-- SONIDO
local sound = Instance.new("Sound")
sound.Parent = Frame
sound.SoundId = "rbxassetid://9118823103"
sound.Volume = 2
sound:Play()

-- BOTÓN CERRAR
local Close = Instance.new("TextButton")
Close.Parent = Frame
Close.Size = UDim2.new(0,30,0,30)
Close.Position = UDim2.new(1,-35,0,5)
Close.Text = "X"
Close.BackgroundColor3 = Color3.fromRGB(255,0,0)
Close.TextColor3 = Color3.new(1,1,1)

Close.MouseButton1Click:Connect(function()
	TweenService:Create(Frame, TweenInfo.new(0.3), {
		Size = UDim2.new(0,0,0,0)
	}):Play()
	
	TweenService:Create(blur, TweenInfo.new(0.3), {Size = 0}):Play()
	
	task.wait(0.3)
	ScreenGui:Destroy()
end)
