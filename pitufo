local function createSlider(parent: Instance, text: string, min: number, max: number, default: number, onChanged: ((number) -> ())?)
	local row = createFrame(parent, UDim2.new(1, 0, 0, 52), UDim2.new(), Theme.Soft, 8, 9)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.fromOffset(12, 6)
	label.Size = UDim2.new(1, -80, 0, 18)
	label.Font = Enum.Font.GothamMedium
	label.Text = text
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Theme.Text
	label.ZIndex = 9
	label.Parent = row

	local value = Instance.new("TextLabel")
	value.BackgroundTransparency = 1
	value.AnchorPoint = Vector2.new(1, 0)
	value.Position = UDim2.new(1, -12, 0, 6)
	value.Size = UDim2.fromOffset(60, 18)
	value.Font = Enum.Font.GothamSemibold
	value.Text = tostring(default)
	value.TextSize = 13
	value.TextXAlignment = Enum.TextXAlignment.Right
	value.TextColor3 = Theme.SubText
	value.ZIndex = 9
	value.Parent = row

	local bar = Instance.new("Frame")
	bar.Position = UDim2.fromOffset(12, 32)
	bar.Size = UDim2.new(1, -24, 0, 8)
	bar.BackgroundColor3 = Color3.fromRGB(52, 55, 72)
	bar.ZIndex = 9
	bar.Parent = row
	makeCorner(bar, 4)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = Theme.Accent
	fill.ZIndex = 10
	fill.Parent = bar
	makeCorner(fill, 4)
	registerAccentObject(fill, "BackgroundColor3")

	local knob = Instance.new("Frame")
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(fill.Size.X.Scale, 0, 0.5, 0)
	knob.Size = UDim2.fromOffset(14, 14)
	knob.BackgroundColor3 = Theme.White
	knob.ZIndex = 11
	knob.Parent = bar
	makeCorner(knob, 7)

	local dragging = false

	local function update(x: number)
		local alpha = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		local v = math.floor(min + (max - min) * alpha + 0.5)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, 0, 0.5, 0)
		value.Text = tostring(v)
		if onChanged then
			onChanged(v)
		end
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			update(UserInputService:GetMouseLocation().X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			update(UserInputService:GetMouseLocation().X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	return row, value
end

local function createToggle(parent: Instance, text: string, default: boolean, onChanged: ((boolean) -> ())?)
	local row = createFrame(parent, UDim2.new(1, 0, 0, 40), UDim2.new(), Theme.Soft, 8, 9)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.fromOffset(12, 0)
	label.Size = UDim2.new(1, -70, 1, 0)
	label.Font = Enum.Font.GothamMedium
	label.Text = text
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextColor3 = Theme.Text
	label.ZIndex = 9
	label.Parent = row

	local pill = Instance.new("Frame")
	pill.AnchorPoint = Vector2.new(1, 0.5)
	pill.Position = UDim2.new(1, -10, 0.5, 0)
	pill.Size = UDim2.fromOffset(42, 22)
	pill.BackgroundColor3 = default and Theme.Accent or Color3.fromRGB(60, 63, 78)
	pill.ZIndex = 9
	pill.Parent = row
	makeCorner(pill, 11)
	registerAccentObject(pill, "BackgroundColor3")

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(16, 16)
	knob.Position = default and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)
	knob.BackgroundColor3 = Theme.White
	knob.ZIndex = 10
	knob.Parent = pill
	makeCorner(knob, 8)

	local state = default

	local function setState(newState: boolean)
		state = newState
		tween(pill, TweenInfo.new(0.15), {
			BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(60, 63, 78)
		})
		tween(knob, TweenInfo.new(0.15), {
			Position = state and UDim2.fromOffset(22, 3) or UDim2.fromOffset(3, 3)
		})
		if onChanged then
			onChanged(state)
		end
	end

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			setState(not state)
			playUISound("rbxassetid://9118828561", 0.18, state and 1.08 or 0.96)
		end
	end)

	return row, function(v: boolean)
		setState(v)
	end
end

