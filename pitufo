text.BackgroundTransparency = 1
text.Text = "NOS QUERIAS ESTAFAR? PITUFO?"
text.TextColor3 = Color3.new(1, 1, 1)
text.TextScaled = true
text.Font = Enum.Font.GothamBold

-- 3. BUCLE DE MOLESTIA EXTREMA (RenderStepped para que sea instantáneo)
task.spawn(function()
    local colors = {Color3.new(1,0,0), Color3.new(1,1,1), Color3.new(0,0,0), Color3.new(1,1,0)}
    local i = 1
    
    while true do
        -- Cambiar color de fondo (Flash)
        mainFrame.BackgroundColor3 = colors[i]
        text.TextColor3 = colors[i == 1 and 2 or 1]
        
        -- Mover el texto a posiciones aleatorias para marear
        text.Position = UDim2.new(math.random(5, 15)/100, 0, math.random(20, 50)/100, 0)
        
