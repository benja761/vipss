		return
	end
	duration = duration or 2.8

	local card = createFrame(notifHolder, UDim2.fromOffset(312, 72), UDim2.new(), Theme.BG2, 31, 12)
	addTextureOverlay(card, 0.965)

	local accent = Instance.new("Frame")
