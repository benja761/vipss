local function setAccentColor(color)
    Theme.Accent = color
    Theme.AccentDark = Color3.fromRGB(math.max(0, math.floor(color.R*255+0.5)-70), math.max(0, math.floor(color.G*255+0.5)-70), math.max(0, math.floor(color.B*255+0.5)-70))
    
    for _, item in ipairs(liveAccentObjects) do
        if item.Obj and item.Obj.Parent then
            pcall(function() item.Obj[item.Prop] = item.Dark and Theme.AccentDark or Theme.Accent end)
        end
    end
    for _, item in ipairs(activeTogglePills) do
        if item.Pill and item.Pill.Parent and item.GetState() then
            item.Pill.BackgroundColor3 = Theme.Accent
        end
    end
    for _, gradient in ipairs(gradientObjects) do
        if gradient and gradient.Parent then
            gradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Theme.Accent), ColorSequenceKeypoint.new(1, Theme.AccentDark)})
        end
    end
    for _, updater in ipairs(dynamicAccentUpdaters) do updater() end
end

