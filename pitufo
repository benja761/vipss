	local waiting = false

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			waiting = true
			State.WaitingForKeybind = true
			value.Text = "Press..."
			value.TextColor3 = Theme.Accent
			notify("Settings", "Press any keyboard key to bind hide / show menu.", 2.4)
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp or not waiting then
			return
		end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
			waiting = false
			State.WaitingForKeybind = false
			value.Text = input.KeyCode.Name
			value.TextColor3 = Theme.SubText
			if onChanged then
				onChanged(input.KeyCode)
			end
			playUISound("rbxassetid://9118823103", 0.22)
			notify("Settings", "Menu key changed to " .. input.KeyCode.Name, 2.6)
		end
	end)

	return row, value
end

