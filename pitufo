local function notify(titleText: string, bodyText: string, duration: number?)
	duration = duration or 3.5
	local card = createFrame(notifHolder, UDim2.fromOffset(300, 64), UDim2.new(), Theme.BG2, 31, 11)
	addTextureOverlay(card, 0.96)

	local accent = Instance.new("Frame")
	accent.Size = UDim2.fromOffset(3, 64)
	accent.BackgroundColor3 = Theme.Accent
	accent.BorderSizePixel = 0
	accent.ZIndex = 32
	accent.Parent = card
	registerAccentObject(accent, "BackgroundColor3")

	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Position = UDim2.fromOffset(14, 8)
	t.Size = UDim2.new(1, -24, 0, 18)
	t.Font = Enum.Font.GothamBold
	t.Text = titleText
	t.TextSize = 13
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextColor3 = Theme.Text
	t.ZIndex = 32
	t.Parent = card

	local b = Instance.new("TextLabel")
	b.BackgroundTransparency = 1
	b.Position = UDim2.fromOffset(14, 28)
	b.Size = UDim2.new(1, -24, 0, 24)
	b.Font = Enum.Font.Gotham
	b.Text = bodyText
	b.TextSize = 12
	b.TextWrapped = true
	b.TextXAlignment = Enum.TextXAlignment.Left
	b.TextYAlignment = Enum.TextYAlignment.Top
	b.TextColor3 = Theme.SubText
	b.ZIndex = 32
	b.Parent = card

	card.Position = UDim2.fromOffset(36, 0)
	card.BackgroundTransparency = 1
	tween(card, TweenInfo.new(0.2), {Position = UDim2.fromOffset(0,0), BackgroundTransparency = 0})

	task.delay(duration, function()
		if not card.Parent then return end
		tween(card, TweenInfo.new(0.18), {Position = UDim2.fromOffset(36,0), BackgroundTransparency = 1})
		task.wait(0.2)
		card:Destroy()
	end)
end

