		local lbl = btn:FindFirstChildOfClass("TextLabel")
		tween(btn, TweenInfo.new(0.15), {BackgroundColor3 = active and Theme.AccentDark or Theme.Soft})
		if lbl then
			tween(lbl, TweenInfo.new(0.15), {TextColor3 = active and Theme.Text or Theme.SubText})
		end
	end
end

local function rebuildSubTabs(pageName: string)
	for _, child in ipairs(subTabsBar:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end
	table.clear(subTabButtons)
	local items = subTabsByPage[pageName] or {"Overview"}
	currentSub = items[1]
	for _, tabName in ipairs(items) do
		subTabButtons[tabName] = makeTabButton(subTabsBar, tabName, 110, function()
			currentSub = tabName
			updateSubButtons()
		end)
	end
	updateSubButtons()
end

local function showPage(name: string)
	currentPage = name
	for pageName, page in pairs(pages) do
		page.Visible = pageName == name
	end
	rebuildSubTabs(name)
	updatePageButtons()
end

