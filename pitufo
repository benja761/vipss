
repeat task.wait() until game:IsLoaded()

local parent = (gethui and gethui()) or game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- LIMPIAR
local old = parent:FindFirstChild("SPAM_PITUFO")
if old then old:Destroy() end

local gui = Instance.new("ScreenGui")
gui.Name = "SPAM_PITUFO"
gui.Parent = parent
gui.ResetOnSpawn = false

-- FUNCION RGB
local function getRGB(t)
	return Color3.fromRGB(
		math.floor(math.sin(t)*127+128),
		math.floor(math.sin(t+2)*127+128),
		math.floor(math.sin(t+4)*127+128)
	)
end

-- SPAM MASIVO
task.spawn(function()
	while gui.Parent do
		for i = 1, 15 do -- cantidad por tick (sube esto si quieres MÁS loco)
			
			local txt = Instance.new("TextLabel")
			txt.Parent = gui
			txt.BackgroundTransparency = 1
			txt.Text = "ME QUERIAS ESTAFAR PITUFO?"
			txt.Font = Enum.Font.GothamBlack
			txt.TextScaled = true
			
			-- tamaño random
			local size = math.random(50, 200)
			txt.Size = UDim2.new(0, size*4, 0, size)
			
			-- posición random
			txt.Position = UDim2.new(
				math.random(),
				0,
				math.random(),
				0
			)

			-- rotación random
			txt.Rotation = math.random(-30, 30)

			-- color RGB dinámico
			local t = tick()
			txt.TextColor3 = getRGB(t)

			-- animación
			local tween = TweenService:Create(txt, TweenInfo.new(0.4), {
				TextTransparency = 1,
				Position = txt.Position + UDim2.new(0, math.random(-50,50), 0, math.random(-50,50))
			})
			
			tween:Play()

			tween.Completed:Connect(function()
				txt:Destroy()
			end)
		end
		
		task.wait(0.03) -- velocidad (bájalo para MÁS spam)
	end
end)

-- EFECTO FLASH GLOBAL
task.spawn(function()
	while gui.Parent do
		local flash = Instance.new("Frame")
		flash.Parent = gui
		flash.Size = UDim2.new(1,0,1,0)
		flash.BackgroundColor3 = getRGB(tick())
		flash.BackgroundTransparency = 0.9
		
		TweenService:Create(flash, TweenInfo.new(0.2), {
			BackgroundTransparency = 1
		}):Play()
		
		task.wait(0.1)
		flash:Destroy()
	end
end)

-- TEXTO CENTRAL FIJO (MÁS IMPACTO)
local center = Instance.new("TextLabel")
center.Parent = gui
center.Size = UDim2.new(0, 800, 0, 200)
center.Position = UDim2.new(0.5, -400, 0.5, -100)
center.BackgroundTransparency = 1
center.Text = "ME QUERIAS ESTAFAR PITUFO?"
center.TextScaled = true
center.Font = Enum.Font.GothamBlack

RunService.RenderStepped:Connect(function()
	center.TextColor3 = getRGB(tick())
	center.Rotation = math.sin(tick()*5)*5
end)
