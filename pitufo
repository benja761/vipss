local function getBox(char)
    if not char or not char.PrimaryPart then return nil end
    local root = char.PrimaryPart
    local top = root.Position + Vector3.new(0,3.6,0)
    local bot = root.Position - Vector3.new(0,3.9,0)
    local tPos = Camera:WorldToViewportPoint(top)
    local bPos = Camera:WorldToViewportPoint(bot)
    if tPos.Z < 0 and bPos.Z < 0 then return nil end
    
    local height = math.abs(tPos.Y - bPos.Y)
    local width = height * 0.58
    
    return {
        TL = Vector2.new(tPos.X - width/2, tPos.Y),
        TR = Vector2.new(tPos.X + width/2, tPos.Y),
        BL = Vector2.new(tPos.X - width/2, bPos.Y),
        BR = Vector2.new(tPos.X + width/2, bPos.Y),
        Center = Vector2.new(tPos.X, (tPos.Y + bPos.Y)/2),
        Width = width, Height = height
    }
end

local function updateESP()
    for plr, d in pairs(espDrawings) do
        local char = plr.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
            for _,v in pairs(d) do if typeof(v)=="table" then for _,l in pairs(v) do l.Visible=false end else v.Visible=false end end
            continue
        end
        
        if State.ESPTeamCheck and plr.Team == LocalPlayer.Team then
            for _,v in pairs(d) do if typeof(v)=="table" then for _,l in pairs(v) do l.Visible=false end else v.Visible=false end end
            continue
        end
        
        local box = getBox(char)
        if not box or not State.ESPEnabled then
            for _,v in pairs(d) do if typeof(v)=="table" then for _,l in pairs(v) do l.Visible=false end else v.Visible=false end end
            continue
        end
        
        local head = char:FindFirstChild("Head")
        local _, visible = head and Camera:WorldToViewportPoint(head.Position) or {Z=1}
        local color = visible.Z > 0 and State.ESPColorVisible or State.ESPColorHidden
        
        -- Box or Corner
        if State.ESPType == "Box" then
            local l = d.BoxLines
            l[1].From, l[1].To = box.TL, box.TR
            l[2].From, l[2].To = box.TR, box.BR
            l[3].From, l[3].To = box.BR, box.BL
            l[4].From, l[4].To = box.BL, box.TL
            for _,line in ipairs(l) do line.Visible = true line.Color = color line.Thickness = State.BoxThickness end
            for _,line in ipairs(d.CornerLines) do line.Visible = false end
        else
            local len = State.CornerLength
            local l = d.CornerLines
            l[1].From = box.TL l[1].To = box.TL + Vector2.new(len,0)
            l[2].From = box.TL l[2].To = box.TL + Vector2.new(0,len)
            l[3].From = box.TR l[3].To = box.TR + Vector2.new(-len,0)
            l[4].From = box.TR l[4].To = box.TR + Vector2.new(0,len)
            l[5].From = box.BL l[5].To = box.BL + Vector2.new(len,0)
            l[6].From = box.BL l[6].To = box.BL + Vector2.new(0,-len)
            l[7].From = box.BR l[7].To = box.BR + Vector2.new(-len,0)
            l[8].From = box.BR l[8].To = box.BR + Vector2.new(0,-len)
            for _,line in ipairs(l) do line.Visible = true line.Color = color line.Thickness = State.BoxThickness end
            for _,line in ipairs(d.BoxLines) do line.Visible = false end
        end
        
        -- Name
        d.NameText.Text = plr.DisplayName
        d.NameText.Position = Vector2.new(box.Center.X, box.TL.Y - (State.ESPNamePosition == "Above" and 22 or 6))
        d.NameText.Color = color
        d.NameText.Visible = true
        
        -- Distance + Health
        if State.ShowDistance then
            local dist = (char.PrimaryPart.Position - (LocalPlayer.Character and LocalPlayer.Character.PrimaryPart.Position or Vector3.zero)).Magnitude
            d.DistText.Text = math.floor(dist) .. "m"
            d.DistText.Position = Vector2.new(box.Center.X, box.BL.Y + 6)
            d.DistText.Color = color
            d.DistText.Visible = true
        else d.DistText.Visible = false end
        
        if State.ShowHealth then
            local hp = math.floor(char.Humanoid.Health)
            d.HealthText.Text = hp
            d.HealthText.Position = Vector2.new(box.TL.X - 26, box.Center.Y)
            d.HealthText.Color = color
            d.HealthText.Visible = true
        else d.HealthText.Visible = false end
        
        -- Health Bar
        if State.ShowHealthBar then
            local hpPercent = char.Humanoid.Health / char.Humanoid.MaxHealth
            d.HealthBarBG.From = Vector2.new(box.TL.X - 8, box.BL.Y)
            d.HealthBarBG.To = Vector2.new(box.TL.X - 8, box.TL.Y)
            d.HealthBarBG.Visible = true
            
            d.HealthBar.From = Vector2.new(box.TL.X - 8, box.BL.Y)
            d.HealthBar.To = Vector2.new(box.TL.X - 8, box.BL.Y - (box.Height * hpPercent))
            d.HealthBar.Color = Color3.fromHSV(hpPercent * 0.33, 1, 1)
            d.HealthBar.Visible = true
        else
            d.HealthBarBG.Visible = false
            d.HealthBar.Visible = false
        end
        
        -- Tracer
        if State.Tracers then
            local origin = State.TracerOrigin == "Mouse" and UserInputService:GetMouseLocation() or
                           State.TracerOrigin == "Top" and Vector2.new(Camera.ViewportSize.X/2, 30) or
                           Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y - 10)
            d.Tracer.From = origin
            d.Tracer.To = Vector2.new(box.Center.X, box.BL.Y)
            d.Tracer.Color = color
            d.Tracer.Visible = true
        else d.Tracer.Visible = false end
        
        -- Skeleton
        if State.SkeletonEnabled then
            local idx = 1
            for _, pair in bonePairs do
                local p1 = char:FindFirstChild(pair[1])
                local p2 = char:FindFirstChild(pair[2])
                if p1 and p2 then
                    local v1, on1 = Camera:WorldToViewportPoint(p1.Position)
                    local v2, on2 = Camera:WorldToViewportPoint(p2.Position)
                    if on1 and on2 then
                        local line = d.SkeletonLines[idx]
                        line.From = Vector2.new(v1.X, v1.Y)
                        line.To = Vector2.new(v2.X, v2.Y)
                        line.Color = color
                        line.Visible = true
                        line.Thickness = State.SkeletonThickness
                        idx += 1
                    end
                end
            end
            for i = idx, #d.SkeletonLines do d.SkeletonLines[i].Visible = false end
        else
            for _, line in d.SkeletonLines do line.Visible = false end
        end
    end
end

