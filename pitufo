local function updateESP()
	fovCircle.Radius = State.FOVRadius
	fovCircle.Visible = State.ShowFOV
	fovCircle.Position = UserInputService:GetMouseLocation()

	for plr, d in pairs(drawings) do
		local char = plr.Character
		if not char or not char:FindFirstChild("Head") or not State.ESPEnabled then
			-- ocultar todo
			continue
		end

		local box = getScreenBox(char)
		if not box then continue end

		local color = State.ESPColor
		local hum = char:FindFirstChild("Humanoid")
		local hp = hum and hum.Health/hum.MaxHealth or 1

		-- Box
		if State.BoxEnabled then
			local b = d.BoxLines
			b[1].From = box.TopLeft b[1].To = box.TopRight
			b[2].From = box.TopRight b[2].To = box.BottomRight
			b[3].From = box.BottomRight b[3].To = box.BottomLeft
			b[4].From = box.BottomLeft b[4].To = box.TopLeft
			for _, l in b do l.Visible = true l.Thickness = State.LineThickness l.Color = color end
		else
			for _, l in d.BoxLines do l.Visible = false end
		end

		-- Corner
		if State.CornerEnabled then
			local c = d.CornerLines
			local len = math.clamp((box.TopRight.X - box.TopLeft.X)/5, 12, 35)
			-- (código corner completo)
			for _, l in c do l.Visible = true l.Thickness = State.LineThickness l.Color = color end
		else
			for _, l in d.CornerLines do l.Visible = false end
		end

		-- Skeleton, Health Bar, Tracers, Name, Distance (todo actualizado con State)
