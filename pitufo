local function rebuildPreviewCharacter()
	if previewModel then
		previewModel:Destroy()
		previewModel = nil
	end

	local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local model = Instance.new("Model")
	model.Name = "PreviewRig"
	model.Parent = viewport
	previewModel = model

	for _, obj in ipairs(char:GetChildren()) do
		if obj:IsA("BasePart")
			or obj:IsA("Accessory")
			or obj:IsA("Shirt")
			or obj:IsA("Pants")
			or obj:IsA("BodyColors")
			or obj:IsA("CharacterMesh")
		then
			obj:Clone().Parent = model
		end
	end

	local cam = viewport.CurrentCamera
	cam.FieldOfView = 32
	model:PivotTo(CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(previewYaw), 0))
	cam.CFrame = CFrame.new(Vector3.new(0, 1.4, 7 - ((previewZoomValue - 90) / 25)), Vector3.new(0, 1.2, 0))

	local light = Instance.new("PointLight")
	light.Range = 16
	light.Brightness = 2
	light.Color = Color3.fromRGB(255, 235, 235)
	light.Parent = cam
end

