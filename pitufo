Players.PlayerRemoving:Connect(function(p) drawings[p] = nil end)

local function getBox(char)
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local size = char:GetExtentsSize() * 1.1
    local cf = root.CFrame
    local points = {
        cf * Vector3.new( size.X/2,  size.Y/2,  size.Z/2),
        cf * Vector3.new( size.X/2,  size.Y/2, -size.Z/2),
        cf * Vector3.new( size.X/2, -size.Y/2,  size.Z/2),
        cf * Vector3.new( size.X/2, -size.Y/2, -size.Z/2),
        cf * Vector3.new(-size.X/2,  size.Y/2,  size.Z/2),
        cf * Vector3.new(-size.X/2,  size.Y/2, -size.Z/2),
        cf * Vector3.new(-size.X/2, -size.Y/2,  size.Z/2),
        cf * Vector3.new(-size.X/2, -size.Y/2, -size.Z/2),
    }
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local onScreen = false
    for _, p in points do
        local v, visible = Camera:WorldToViewportPoint(p)
        if visible then
            onScreen = true
            minX = math.min(minX, v.X)
            minY = math.min(minY, v.Y)
            maxX = math.max(maxX, v.X)
            maxY = math.max(maxY, v.Y)
        end
    end
    if not onScreen then return nil end
    return {
        TL = Vector2.new(minX, minY),
        TR = Vector2.new(maxX, minY),
        BL = Vector2.new(minX, maxY),
        BR = Vector2.new(maxX, maxY),
        Center = Vector2.new((minX+maxX)/2, (minY+maxY)/2)
    }
end

local function updateESP()
    for plr, d in pairs(drawings) do
        local char = plr.Character
        if not char or not char:FindFirstChild("Head") or not State.ESPEnabled then
            for _, tbl in pairs(d) do
                if typeof(tbl) == "table" then
                    for _, line in pairs(tbl) do line.Visible = false end
                else
                    tbl.Visible = false
                end
            end
            continue
        end
        
        local box = getBox(char)
        if not box then
            for _, tbl in pairs(d) do
                if typeof(tbl) == "table" then
                    for _, line in pairs(tbl) do line.Visible = false end
                else
                    tbl.Visible = false
                end
            end
            continue
        end
        
        local color = State.ESPColor
        local hum = char:FindFirstChild("Humanoid")
        local healthPercent = hum and hum.Health / hum.MaxHealth or 1
        
        -- Box
        if State.BoxEnabled then
            local b = d.Box
            b[1].From = box.TL; b[1].To = box.TR
            b[2].From = box.TR; b[2].To = box.BR
            b[3].From = box.BR; b[3].To = box.BL
            b[4].From = box.BL; b[4].To = box.TL
            for _, line in ipairs(b) do
                line.Visible = true
                line.Thickness = State.LineThickness
                line.Color = color
            end
        else
            for _, line in ipairs(d.Box) do line.Visible = false end
        end
        
        -- Corner
        if State.CornerEnabled then
            local c = d.Corner
            local len = math.clamp((box.TR.X - box.TL.X) / 5, 12, 35)
            -- Top Left
            c[1].From = box.TL; c[1].To = box.TL + Vector2.new(len,0)
            c[2].From = box.TL; c[2].To = box.TL + Vector2.new(0,len)
            -- Top Right
            c[3].From = box.TR; c[3].To = box.TR + Vector2.new(-len,0)
            c[4].From = box.TR; c[4].To = box.TR + Vector2.new(0,len)
            -- Bottom Left
            c[5].From = box.BL; c[5].To = box.BL + Vector2.new(len,0)
            c[6].From = box.BL; c[6].To = box.BL + Vector2.new(0,-len)
            -- Bottom Right
            c[7].From = box.BR; c[7].To = box.BR + Vector2.new(-len,0)
            c[8].From = box.BR; c[8].To = box.BR + Vector2.new(0,-len)
            for _, line in ipairs(c) do
                line.Visible = true
                line.Thickness = State.LineThickness
                line.Color = color
            end
        else
            for _, line in ipairs(d.Corner) do line.Visible = false end
        end
        
        -- Skeleton
        if State.SkeletonEnabled then
            local idx = 1
            for _, pair in bonePairs do
                local p1 = char:FindFirstChild(pair[1])
                local p2 = char:FindFirstChild(pair[2])
                if p1 and p2 then
                    local v1, on1 = Camera:WorldToViewportPoint(p1.Position)
                    local v2, on2 = Camera:WorldToViewportPoint(p2.Position)
                    if on1 and on2 then
                        local line = d.Skeleton[idx]
                        line.From = Vector2.new(v1.X, v1.Y)
                        line.To = Vector2.new(v2.X, v2.Y)
                        line.Visible = true
                        line.Thickness = State.SkeletonThickness
                        line.Color = color
                        idx += 1
                    end
                end
            end
        else
            for _, line in ipairs(d.Skeleton) do line.Visible = false end
        end
        
        -- Health Bar
        if State.HealthBarEnabled then
            local barX = box.TR.X + 6
            local barHeight = box.BR.Y - box.TR.Y
            local barY = box.TR.Y
            d.HealthBar[1].From = Vector2.new(barX, barY)
            d.HealthBar[1].To = Vector2.new(barX, barY + barHeight)
            d.HealthBar[1].Color = Color3.fromRGB(30,30,30)
            d.HealthBar[1].Thickness = 6
            d.HealthBar[1].Visible = true
            
            d.HealthBar[2].From = Vector2.new(barX, barY + barHeight)
            d.HealthBar[2].To = Vector2.new(barX, barY + barHeight * (1 - healthPercent))
            d.HealthBar[2].Color = Color3.fromRGB(0,255,0)
            d.HealthBar[2].Thickness = 4
            d.HealthBar[2].Visible = true
        else
            for _, line in ipairs(d.HealthBar) do line.Visible = false end
        end
        
        -- Tracer
        if State.TracersEnabled then
            d.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            d.Tracer.To = Vector2.new(box.Center.X, box.BR.Y)
            d.Tracer.Color = color
            d.Tracer.Thickness = 1.5
            d.Tracer.Visible = true
        else
            d.Tracer.Visible = false
        end
        
        -- Name
        d.Name.Text = plr.DisplayName
        d.Name.Visible = true
        if State.NamePosition == "Above" then
            d.Name.Position = Vector2.new(box.Center.X, box.TL.Y - 24)
        elseif State.NamePosition == "Middle" then
            d.Name.Position = Vector2.new(box.Center.X, box.Center.Y - 8)
        else
            d.Name.Position = Vector2.new(box.Center.X, box.BR.Y + 8)
        end
        
        -- Distance
        if State.DistanceEnabled then
            local dist = math.floor((LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (char.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude) or 0)
            d.Distance.Text = dist .. "m"
            d.Distance.Position = Vector2.new(box.Center.X, box.BR.Y + 26)
            d.Distance.Visible = true
        else
            d.Distance.Visible = false
        end
    end
end

RunService.RenderStepped:Connect(updateESP)

-- ==================== AIMBOT (mantiene el anterior) ====================
local isAiming = false
local aimConn = nil

UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not State.AimEnabled then return end
    if input.KeyCode == State.AimKey then
        isAiming = true
        if not aimConn then
            aimConn = RunService.RenderStepped:Connect(function()
                if not isAiming then return end
                local closest = nil
                local closestDist = math.huge
                local mouse = UserInputService:GetMouseLocation()
                
                for _, plr in Players:GetPlayers() do
                    if plr == LocalPlayer or not plr.Character then continue end
                    local part = plr.Character:FindFirstChild(State.TargetPart) or plr.Character:FindFirstChild("Head")
                    if part then
                        local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local dist = (Vector2.new(screen.X, screen.Y) - mouse).Magnitude
                            if dist < 300 and dist < closestDist then
                                closestDist = dist
                                closest = part
                            end
                        end
                    end
                end
                
                if closest then
                    local targetCF = CFrame.lookAt(Camera.CFrame.Position, closest.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(targetCF, 1 / (State.AimSmooth + 8))
                end
            end)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == State.AimKey then
        isAiming = false
        if aimConn then aimConn:Disconnect() aimConn = nil end
    end
end)

