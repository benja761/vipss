local function tween(obj: Instance, info: TweenInfo, props: {[string]: any})
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function makeCorner(obj: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
	return c
end

local function makeStroke(obj: Instance, color: Color3, thickness: number, transparency: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = obj
	return s
end

local function addList(parent: Instance, padding: number)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, padding)
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function createFrame(parent: Instance, size: UDim2, pos: UDim2, color: Color3, z: number, radius: number)
	local frame = Instance.new("Frame")
	frame.Size = size
	frame.Position = pos
	frame.BackgroundColor3 = color
	frame.BorderSizePixel = 0
	frame.ZIndex = z
	frame.Parent = parent
	makeCorner(frame, radius)
	makeStroke(frame, Theme.Stroke, 1)
	return frame
end

local function addTextureOverlay(parent: Instance, transparency: number)
	local tex = Instance.new("ImageLabel")
	tex.Name = "TextureOverlay"
	tex.BackgroundTransparency = 1
	tex.Size = UDim2.fromScale(1, 1)
	tex.Image = "rbxassetid://9968344105"
	tex.ImageTransparency = transparency
	tex.ScaleType = Enum.ScaleType.Crop
	tex.ZIndex = parent.ZIndex + 1
	tex.Parent = parent
	makeCorner(tex, 16)
	return tex
end

local function accentRGBString(color: Color3): string
	return string.format("%d,%d,%d", math.floor(color.R * 255 + 0.5), math.floor(color.G * 255 + 0.5), math.floor(color.B * 255 + 0.5))
end

local function registerAccentObject(obj: Instance, prop: string, useDark: boolean?)
	table.insert(liveAccentObjects, {
		Obj = obj,
		Prop = prop,
		Dark = useDark == true,
	})
end

local function registerGradient(g: UIGradient)
	table.insert(gradientObjects, g)
end

local function registerDynamicAccentUpdater(fn: () -> ())
	table.insert(dynamicAccentUpdaters, fn)
end

local function playUISound(id: string, volume: number, speed: number?)
	if not State.SoundsEnabled then
		return
	end
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume
	s.PlaybackSpeed = speed or 1
	s.Parent = SoundService
	s:Play()
	s.Ended:Connect(function()
		s:Destroy()
	end)
	task.delay(3, function()
		if s.Parent then
			s:Destroy()
		end
	end)
end

