	arrow.Text = "▾"
	arrow.TextSize = 14
	arrow.TextColor3 = Theme.SubText
	arrow.ZIndex = 9
	arrow.Parent = row

	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			currentIndex += 1
