local isAiming = false
local aimConnection = nil

UserInputService.InputBegan:Connect(function(input, gp)
	if gp or not State.AimEnabled then return end
	if input.KeyCode == State.AimKey then
		isAiming = true
		if not aimConnection then
			aimConnection = RunService.RenderStepped:Connect(function()
				if not isAiming then return end
				local target = getClosestTarget() -- misma función que tenías
				if target then
					local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
					Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.35 / State.AimSmooth)
				end
			end)
		end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == State.AimKey then
		isAiming = false
		if aimConnection then aimConnection:Disconnect() aimConnection = nil end
	end
end)

