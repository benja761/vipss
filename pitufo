local function createToggle(parent, text, default, onChanged)
	local row = createFrame(parent, UDim2.new(1,0,0,40), UDim2.new(), Theme.Soft, 8, 10)
	local label = Instance.new("TextLabel") label.Position = UDim2.fromOffset(12,0) label.Size = UDim2.new(1,-72,1,0) label.Font = Enum.Font.GothamMedium label.Text = text label.TextColor3 = Theme.Text label.Parent = row
	local pill = Instance.new("Frame") pill.AnchorPoint = Vector2.new(1,0.5) pill.Position = UDim2.new(1,-10,0.5,0) pill.Size = UDim2.fromOffset(42,22) pill.BackgroundColor3 = default and Theme.Accent or Color3.fromRGB(60,63,78) pill.Parent = row makeCorner(pill,11)
	local knob = Instance.new("Frame") knob.Size = UDim2.fromOffset(16,16) knob.Position = default and UDim2.fromOffset(22,3) or UDim2.fromOffset(3,3) knob.BackgroundColor3 = Theme.White knob.Parent = pill makeCorner(knob,8)
	local state = default
	table.insert(activeTogglePills, {Pill = pill, GetState = function() return state end})
	local function setState(v) state = v tween(pill, TweenInfo.new(0.15), {BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(60,63,78)}) tween(knob, TweenInfo.new(0.15), {Position = state and UDim2.fromOffset(22,3) or UDim2.fromOffset(3,3)}) if onChanged then onChanged(state) end end
	row.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then setState(not state) playUISound("rbxassetid://9118828561", 0.16) end end)
	return row, setState
end

local function createSlider(parent, text, min, max, default, onChanged)
	local row = createFrame(parent, UDim2.new(1,0,0,54), UDim2.new(), Theme.Soft, 8, 10)
	local label = Instance.new("TextLabel") label.Position = UDim2.fromOffset(12,6) label.Size = UDim2.new(1,-82,0,18) label.Font = Enum.Font.GothamMedium label.Text = text label.TextColor3 = Theme.Text label.Parent = row
	local value = Instance.new("TextLabel") value.AnchorPoint = Vector2.new(1,0) value.Position = UDim2.new(1,-12,0,6) value.Size = UDim2.fromOffset(62,18) value.Font = Enum.Font.GothamSemibold value.Text = tostring(default) value.TextColor3 = Theme.SubText value.Parent = row
	local bar = Instance.new("Frame") bar.Position = UDim2.fromOffset(12,34) bar.Size = UDim2.new(1,-24,0,8) bar.BackgroundColor3 = Color3.fromRGB(52,56,73) bar.Parent = row makeCorner(bar,4)
	local fill = Instance.new("Frame") fill.Size = UDim2.new((default-min)/(max-min),0,1,0) fill.BackgroundColor3 = Theme.Accent fill.Parent = bar makeCorner(fill,4) registerAccentObject(fill, "BackgroundColor3")
	local knob = Instance.new("Frame") knob.AnchorPoint = Vector2.new(0.5,0.5) knob.Position = UDim2.new(fill.Size.X.Scale,0,0.5,0) knob.Size = UDim2.fromOffset(14,14) knob.BackgroundColor3 = Theme.White knob.Parent = bar makeCorner(knob,7)
	local dragging = false
	local function update(x)
		local alpha = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		local val = math.floor(min + (max - min) * alpha + 0.5)
		fill.Size = UDim2.new(alpha,0,1,0)
		knob.Position = UDim2.new(alpha,0,0.5,0)
		value.Text = tostring(val)
		if onChanged then onChanged(val) end
	end
	bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(UserInputService:GetMouseLocation().X) end end)
	UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(UserInputService:GetMouseLocation().X) end end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
	return row, value
end

local function createDropdown(parent, text, values, defaultIndex, onChanged)
	local row = createFrame(parent, UDim2.new(1,0,0,40), UDim2.new(), Theme.Soft, 8, 10)
	local label = Instance.new("TextLabel") label.Position = UDim2.fromOffset(12,0) label.Size = UDim2.new(0.56,0,1,0) label.Font = Enum.Font.GothamMedium label.Text = text label.TextColor3 = Theme.Text label.Parent = row
	local currentIndex = defaultIndex or 1
	local value = Instance.new("TextLabel") value.AnchorPoint = Vector2.new(1,0) value.Position = UDim2.new(1,-34,0,0) value.Size = UDim2.new(0.34,0,1,0) value.Font = Enum.Font.Gotham value.Text = values[currentIndex] value.TextColor3 = Theme.SubText value.Parent = row
	row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			currentIndex += 1 if currentIndex > #values then currentIndex = 1 end
			value.Text = values[currentIndex]
			if onChanged then onChanged(values[currentIndex]) end
		end
	end)
	return row, value
end

