-- LÓGICA DEL MARTILLO (BORRAR PAREDES)
--------------------------------
local function manageHammer()
    if deleteWallsEnabled then
        local tool = Instance.new("Tool")
        tool.Name = "Martillo Invisible"
        tool.RequiresHandle = false
        tool.Parent = player.Backpack

        tool.Activated:Connect(function()
            local mouse = player:GetMouse()
            if mouse.Target and mouse.Target:IsA("BasePart") then
                mouse.Target:Destroy()
            end
        end)
    else
        local t1 = player.Backpack:FindFirstChild("Martillo Invisible")
        local t2 = player.Character:FindFirstChild("Martillo Invisible")
        if t1 then t1:Destroy() end
        if t2 then t2:Destroy() end
    end
end

