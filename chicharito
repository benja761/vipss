--- SECCIÓN DE MONITOR DE DINERO (ACCOUNT CASH) ---
local player = game.Players.LocalPlayer
-- AJUSTE: Si el dinero no se llama "Money", cámbialo aquí abajo por "Cash" o "Beli"
local moneyName = "Money" 

local CashLabel = StatsTab:CreateLabel("Account Cash: " .. player.leaderstats[moneyName].Value)

-- Bucle de actualización automática
task.spawn(function()
    while task.wait(0.5) do
        if player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild(moneyName) then
            local currentCash = player.leaderstats[moneyName].Value
            CashLabel:Set("Account Cash: " .. currentCash)
        end
    end
end)
