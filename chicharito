local function createBtn(name, key, callback)
    local btn = Instance.new("TextButton", btnList)
    btn.Size = UDim2.new(1, 0, 0, 38)
    btn.BackgroundColor3 = fondoBotones
    btn.Text = name .. " (" .. key .. ") [OFF]"
    btn.TextColor3 = blanco
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        local state = callback()
        btn.BackgroundColor3 = state and verdeActivo or fondoBotones
        btn.Text = name .. " (" .. key .. ") [" .. (state and "ON" or "OFF") .. "]"
    end)
    return btn
end

