--------------------------------
-- FUNCIÓN CHAMS (ESP)
--------------------------------
local function applyChams(char)
    local highlight = char:FindFirstChild("PitufoChams")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "PitufoChams"
        highlight.Parent = char
    end
    highlight.FillColor = moradoBorde
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = blanco
    highlight.OutlineTransparency = 0
    highlight.Enabled = espEnabled
end

--------------------------------
-- BUCLE DE SISTEMAS
--------------------------------
RunService.RenderStepped:Connect(function()
    local fps = math.floor(1/RunService.RenderStepped:Wait())
    local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    statsL.Text = "FPS: "..fps.."\nPing: "..ping.."ms"

    local mouseLoc = UIS:GetMouseLocation()
    fovCircle.Position = mouseLoc
    fovCircle.Visible = (logged and fovVisible)

    -- Lógica de ESP (Chams)
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character then
            if espEnabled and logged then
                applyChams(v.Character)
            else
                local h = v.Character:FindFirstChild("PitufoChams")
                if h then h.Enabled = false end
            end
        end
    end

    if aimbotEnabled and logged then
        local target = nil
        local dist = fovCircle.Radius
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("Head") then
                local pos, vis = camera:WorldToViewportPoint(v.Character.Head.Position)
                if vis then
                    local mDist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                    if mDist < dist then
                        dist = mDist
                        target = v
                    end
                end
            end
        end
        if target then camera.CFrame = CFrame.new(camera.CFrame.Position, target.Character.Head.Position) end
    end
end)

RunService.Stepped:Connect(function()
    if noclipEnabled and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

