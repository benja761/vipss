        Size = withPreview and UDim2.new(0.385, -6, 1, 0) or UDim2.new(0.49, -6, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 3,
        ScrollingDirection = Enum.ScrollingDirection.Y,
    })
    local preview
    if withPreview then
        preview = New("Frame", {
            Parent = parent,
            Position = UDim2.new(0.79, 8, 0, 0),
            Size = UDim2.new(0.21, -8, 1, 0),
            BackgroundColor3 = Theme.Panel,
            BorderSizePixel = 0,
        })
        Corner(preview, 8)
        Stroke(preview, Theme.Border, 1, 0.4)
        local plabel = New("TextLabel", {
            Parent = preview,
            Position = UDim2.new(0, 12, 0, 8),
            Size = UDim2.new(1, -24, 0, 18),
            BackgroundTransparency = 1,
            Font = Enum.Font.GothamBold,
            Text = "ESP Preview",
            TextSize = 12,
            TextColor3 = Theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left,
        })
        local divider = New("Frame", {
            Parent = preview,
            Position = UDim2.new(0, 0, 0, 34),
            Size = UDim2.new(1, 0, 0, 1),
            BorderSizePixel = 0,
            BackgroundColor3 = Theme.Border,
        })
        local viewportBack = New("Frame", {
            Parent = preview,
            Position = UDim2.new(0, 10, 0, 44),
            Size = UDim2.new(1, -20, 1, -54),
            BackgroundColor3 = Color3.fromRGB(7, 10, 16),
            BorderSizePixel = 0,
        })
        Corner(viewportBack, 8)
        Stroke(viewportBack, Theme.Border, 1, 0.65)
        local viewport = New("ViewportFrame", {
            Parent = viewportBack,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
        })
        local cam = Instance.new("Camera")
        cam.Parent = viewport
        viewport.CurrentCamera = cam
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local clone = char:Clone()
        for _, v in ipairs(clone:GetDescendants()) do
            if v:IsA("LocalScript") or v:IsA("Script") or v:IsA("ModuleScript") then
                v:Destroy()
            elseif v:IsA("BasePart") then
                v.Anchored = true
                v.CanCollide = false
            end
        end
        clone.Parent = viewport
        local root = clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChildWhichIsA("BasePart")
        if root then
            clone:PivotTo(CFrame.new(0, -1, 0))
            cam.CFrame = CFrame.new(Vector3.new(0, 1.4, 5.2), Vector3.new(0, 1.2, 0))
        end
    end
    for _, sc in ipairs({left, right}) do
        local layout = New("UIListLayout", {Parent = sc, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder})
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sc.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
        end)
    end
    return left, right, preview
end

