        if state then
            if not eff then
                eff = Instance.new("BlurEffect")
                eff.Name = "ValaryDepthBlur"
                eff.Size = 8
                eff.Parent = Lighting
            end
        else
            if eff then
                eff:Destroy()
            end
        end
    end

    function self:ApplyBlurEnabled(state)
        self._BlurEnabled = state and true or false
        if self.Blur then
            self.Blur.Size = self._BlurEnabled and 4 or 0
        end
    end

    function self:ApplyBlurSize(value)
        if self.Blur and self._BlurEnabled then
            self.Blur.Size = tonumber(value) or 0
        end
    end

    function self:ApplyFOV(value)
        self.BaseFOV = tonumber(value) or 70
        local cam = workspace.CurrentCamera
        if cam then
            if self.StretchEnabled then
                cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
            else
                cam.FieldOfView = self.BaseFOV
            end
        end
    end

    function self:ApplyStretchEnabled(state)
        self.StretchEnabled = state and true or false
        local cam = workspace.CurrentCamera
        if cam then
            if self.StretchEnabled then
                cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
            else
                cam.FieldOfView = self.BaseFOV
            end
        end
    end

    function self:ApplyStretchAmount(value)
        self.StretchAmount = tonumber(value) or 0
        local cam = workspace.CurrentCamera
        if cam and self.StretchEnabled then
            cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
        end
    end

    function self:ApplyFogEnd(value)
        Lighting.FogEnd = tonumber(value) or 100000
    end

    function self:ApplyExposure(value)
        Lighting.ExposureCompensation = tonumber(value) or 0
    end

    function self:ApplyColorShiftTop(color)
        Lighting.ColorShift_Top = color
    end

    function self:ApplyColorShiftBottom(color)
        Lighting.ColorShift_Bottom = color
    end

    function self:ApplyShadows(state)
        Lighting.GlobalShadows = state and true or false
    end

    function self:ApplyPreviewVisible(state)
        self.PreviewState.Visible = state and true or false
        if state then
