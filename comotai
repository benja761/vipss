        if self.BrandAccent then
            self.BrandAccent.TextColor3 = color
        end

        for _, obj in ipairs(self.AccentObjects or {}) do
            if obj and obj.Parent then
                local mode = obj:GetAttribute("AccentMode")
                if mode == "bg" then
                    obj.BackgroundColor3 = color
                elseif mode == "stroke" then
                    obj.Color = color
                elseif mode == "text" then
                    obj.TextColor3 = color
                end
            end
        end

        for _, toggleData in ipairs(self.LiveToggles or {}) do
            if toggleData and toggleData.Render and toggleData.Switch and toggleData.Switch.Parent then
                toggleData.Render()
            end
        end

        self:UpdatePreviewESP()
        self:UpdateCombatOverlay()
    end

