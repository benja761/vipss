local mainButtons, subButtons = {}, {}

local function ClearSubs()
    for _, v in ipairs(subTabs:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    table.clear(subButtons)
end

local function ShowPage(mainName, subName)
    for k, page in pairs(pages) do
        page.Visible = (k == (mainName .. ":" .. subName))
    end
    currentMain, currentSub = mainName, subName
    for name, btn in pairs(mainButtons) do
        btn.BackgroundColor3 = (name == mainName) and Theme.Element2 or Theme.Panel
        local st = btn:FindFirstChildOfClass("UIStroke")
        if st then st.Color = (name == mainName) and Theme.Accent or Theme.Border end
        local txt = btn:FindFirstChild("TabText")
        if txt then txt.TextColor3 = (name == mainName) and Theme.Accent or Theme.Sub end
    end
    for name, btn in pairs(subButtons) do
        btn.BackgroundColor3 = (name == subName) and Theme.Element2 or Theme.Panel
        local st = btn:FindFirstChildOfClass("UIStroke")
        if st then st.Color = (name == subName) and Theme.Accent or Theme.Border end
    end
end

