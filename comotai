    RelayoutNotifications()

    Tween(card, TweenInfo.new(0.18), {Size = UDim2.new(0, 304, 0, 44)})
    Tween(shadow, TweenInfo.new(0.18), {Size = UDim2.new(0, 304, 0, 44)})
