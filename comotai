    function self:ApplyAmbientEnabled(enabled, color)
        self._AmbientEnabled = enabled and true or false
        if self._AmbientEnabled then
            local c = color or self._AmbientColor or Theme.Accent
            Lighting.Ambient = c
            Lighting.OutdoorAmbient = c
        else
            Lighting.Ambient = self._OriginalLighting.Ambient
            Lighting.OutdoorAmbient = self._OriginalLighting.OutdoorAmbient
        end
    end

    function self:ApplyAmbientColor(color)
        self._AmbientColor = color
        if self._AmbientEnabled then
            Lighting.Ambient = color
            Lighting.OutdoorAmbient = color
        end
    end

    function self:ApplyFullbright(state)
        if state then
            Lighting.Brightness = 3
            Lighting.GlobalShadows = false
            Lighting.Ambient = Color3.fromRGB(200, 200, 200)
            Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
        else
            Lighting.GlobalShadows = self._OriginalLighting.GlobalShadows
            Lighting.Brightness = self._OriginalLighting.Brightness
            if self._AmbientEnabled then
                Lighting.Ambient = self._AmbientColor
                Lighting.OutdoorAmbient = self._AmbientColor
            else
                Lighting.Ambient = self._OriginalLighting.Ambient
                Lighting.OutdoorAmbient = self._OriginalLighting.OutdoorAmbient
            end
        end
    end

    function self:ApplyDepthBlur(state)
