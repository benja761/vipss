            Text = "ESP Preview",
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextColor3 = Theme.Text,
            TextSize = 12,
        })

        local viewport = Create("ViewportFrame", {
            Parent = preview,
            BackgroundColor3 = Theme.Main2,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 10, 0, 34),
            Size = UDim2.new(1, -20, 1, -46),
        })
        Corner(viewport, 6)
        Stroke(viewport, Theme.Border, 1)

        self.PreviewViewport = viewport
        self.PreviewPanel = preview

        local clone = cloneCharacter(viewport)

        if self.PreviewConn then
            self.PreviewConn:Disconnect()
            self.PreviewConn = nil
        end

        self.PreviewConn = RunService.RenderStepped:Connect(function(dt)
            if clone and clone.Parent and clone.PrimaryPart then
                pcall(function()
                    clone:PivotTo(clone:GetPivot() * CFrame.Angles(0, math.rad(self.PreviewRotationSpeed * dt), 0))
                end)
            end

            if self.PulseFrame and self.PulseFrame.Visible then
                local base = self.CombatState.PulseSize
                local grow = math.sin(tick() * 2.5) * 8
                self.PulseFrame.Size = UDim2.new(0, base + grow, 0, base + grow)
            end
        end)

        if self.CharacterAddedConn then
            self.CharacterAddedConn:Disconnect()
            self.CharacterAddedConn = nil
        end

        self.CharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.7)
            clone = cloneCharacter(viewport)
            task.wait(0.2)
            self:UpdatePreviewESP()
        end)

        self:EnsurePreviewESP()
        self:UpdatePreviewESP()
    end


