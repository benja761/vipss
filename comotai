            self:ApplyFogEnd(500)
            self:ApplyExposure(-0.2)
            Lighting.ColorShift_Top = Color3.fromRGB(0, 20, 50)
            Lighting.ColorShift_Bottom = Color3.fromRGB(0, 0, 20)
