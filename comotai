        Tween(card, TweenInfo.new(0.18), {Position = UDim2.new(1, 50, card.Position.Y.Scale, card.Position.Y.Offset), BackgroundTransparency = 1})
        Tween(shadow, TweenInfo.new(0.18), {Position = UDim2.new(1, 30, shadow.Position.Y.Scale, shadow.Position.Y.Offset), BackgroundTransparency = 1})
        task.wait(0.22)
        if card.Parent then card:Destroy() end
        if shadow.Parent then shadow:Destroy() end
        RelayoutNotifications()
    end)
