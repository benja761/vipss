        if self.PreviewPanel and self.PreviewPanel.Parent then
            self.PreviewPanel.Visible = true
            self:UpdatePreviewESP()
            return
        end

        local preview = Create("Frame", {
            Parent = main,
            BackgroundColor3 = Theme.Panel,
