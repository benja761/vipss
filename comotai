            right:AddToggle("Visible Check", false, function(v)
                self.PreviewState.VisibleCheck = v
            end)
        end

        local preview = visualsTab:AddSubTab("Preview")
        do
            local left = preview:AddSection("Preview Values", "left")
            left:AddSlider("Name Size", 10, 24, 14, function(v)
                self.PreviewState.NameSize = v
                self:UpdatePreviewESP()
            end)
            left:AddSlider("Distance Size", 10, 22, 12, function(v)
                self.PreviewState.DistanceSize = v
                self:UpdatePreviewESP()
            end)
            left:AddSlider("Distance Value", 1, 500, 23, function(v)
                self.PreviewState.DistanceValue = math.floor(v)
                self:UpdatePreviewESP()
            end)
            left:AddSlider("Health Value", 1, 100, 86, function(v)
                self.PreviewState.HealthValue = math.floor(v)
                self:UpdatePreviewESP()
            end)

            local right = preview:AddSection("ESP Colors", "right")
            right:AddColorPicker("Box Color", Color3.fromRGB(255, 255, 255), function(c)
                self.PreviewState.BoxColor = c
                self:UpdatePreviewESP()
            end)
            right:AddColorPicker("Name Color", Color3.fromRGB(255, 255, 255), function(c)
                self.PreviewState.NameColor = c
                self:UpdatePreviewESP()
            end)
            right:AddColorPicker("Distance Color", Color3.fromRGB(190, 190, 190), function(c)
                self.PreviewState.DistanceColor = c
                self:UpdatePreviewESP()
            end)
            right:AddColorPicker("Health Color", Color3.fromRGB(0, 255, 140), function(c)
                self.PreviewState.HealthColor = c
                self:UpdatePreviewESP()
            end)
            right:AddColorPicker("Tracer Color", Color3.fromRGB(255, 255, 255), function(c)
                self.PreviewState.TracerColor = c
            end)
            right:AddColorPicker("Skeleton Color", Color3.fromRGB(255, 255, 255), function(c)
                self.PreviewState.SkeletonColor = c
            end)
        end

        local world = visualsTab:AddSubTab("World")
        do
            local left = world:AddSection("World Settings", "left")
            left:AddToggle("Ambient Enabled", false, function(v)
                self:ApplyAmbientEnabled(v, self._AmbientColor)
            end)
            left:AddColorPicker("Ambient Color", Color3.fromRGB(255, 190, 40), function(c)
                self:ApplyAmbientColor(c)
            end)
            left:AddSlider("Brightness", 0, 10, 2, function(v)
                self:ApplyBrightness(v)
            end)
            left:AddSlider("Clock Time", 0, 24, 14, function(v)
                self:ApplyClockTime(v)
            end)
            left:AddSlider("Fog End", 100, 100000, 100000, function(v)
                self:ApplyFogEnd(v)
            end)

            local right = world:AddSection("Camera", "right")
            right:AddSlider("Field Of View", 40, 120, 70, function(v)
                self:ApplyFOV(v)
            end)
            right:AddToggle("Enabled Resolution", false, function(v)
                self:ApplyStretchEnabled(v)
            end)
            right:AddSlider("Stretch Amount", 0, 40, 0, function(v)
                self:ApplyStretchAmount(v)
            end)
            right:AddToggle("Fullbright", false, function(v)
                self:ApplyFullbright(v)
            end)
            right:AddToggle("Depth Blur", false, function(v)
                self:ApplyDepthBlur(v)
            end)
        end

        ----------------------------------------------------------------
        -- AUTO FARM
        ----------------------------------------------------------------
        local farm = autoFarmTab:AddSubTab("Auto Farm")
        do
            local left = farm:AddSection("Marshmellow Farm", "left")
            left:AddToggle("Auto Buy Marshmellow", false)
            left:AddSlider("Marshmellow Amount", 0, 10000, 1000)
            left:AddToggle("Auto Eat Marshmellow", false)
            left:AddToggle("Auto Refill", false)

            local right = farm:AddSection("Farm Options", "right")
            right:AddToggle("Auto Collect", false)
            right:AddToggle("Auto Sell", false)
            right:AddToggle("Auto Rejoin", false)
            right:AddDropdown("Rejoin Method", {"Server Hop", "Same Server", "Last Server"}, "Server Hop")
            right:AddButton("Show Farm Status", function()
                self:Notify("Auto Farm UI only")
            end)
        end

        ----------------------------------------------------------------
        -- SETTINGS
        ----------------------------------------------------------------
        local settingsUI = settingsTab:AddSubTab("UI")
        do
            local left = settingsUI:AddSection("Menu Effects", "left")
            left:AddToggle("Blur Enabled", true, function(v)
                self:ApplyBlurEnabled(v)
            end)
            left:AddSlider("Blur Size", 0, 20, 4, function(v)
                self:ApplyBlurSize(v)
            end)
            left:AddToggle("Show Bottom Tabs", true, function(v)
                self:ApplyBottomTabsVisible(v)
            end)
            left:AddToggle("Menu Sounds", true, function(v)
                self:ApplyMenuSounds(v)
            end)
            left:AddToggle("Smooth Open", true, function(v)
                self:ApplySmoothOpen(v)
            end)

            local right = settingsUI:AddSection("Theme", "right")
            right:AddColorPicker("UI Accent", Theme.Accent, function(c)
                self:ApplyAccentColor(c)
            end, true)
            right:AddDropdown("Preset", {"Gold", "Purple", "Blue", "Green", "Red", "White", "Orange"}, "Gold", function(v)
                if v == "Gold" then self:SetAccent(Color3.fromRGB(255, 190, 40)) end
                if v == "Purple" then self:SetAccent(Color3.fromRGB(160, 100, 255)) end
                if v == "Blue" then self:SetAccent(Color3.fromRGB(0, 170, 255)) end
                if v == "Green" then self:SetAccent(Color3.fromRGB(0, 255, 140)) end
                if v == "Red" then self:SetAccent(Color3.fromRGB(255, 70, 70)) end
                if v == "White" then self:SetAccent(Color3.fromRGB(230, 230, 230)) end
                if v == "Orange" then self:SetAccent(Color3.fromRGB(255, 140, 0)) end
            end)
            right:AddSlider("UI Scale", 0.8, 1.3, 1, function(v)
                self:ApplyUIScale(v)
            end)
            right:AddKeybind("Hide Key", Enum.KeyCode.Z, function(key)
                self:ApplyHideKey(key)
            end)
        end

        local settingsConfig = settingsTab:AddSubTab("Config")
        do
            local left = settingsConfig:AddSection("Config", "left")
            left:AddDropdown("Config Slot", {"Default", "Legit", "Visual"}, "Default")
            left:AddButton("Load Config", function()
                self:Notify("Load clicked")
            end)
            left:AddButton("Save Config", function()
                self:Notify("Save clicked")
            end)
            left:AddButton("Reset Config", function()
                self:Notify("Reset clicked")
            end)

            local right = settingsConfig:AddSection("Preview Tools", "right")
            right:AddButton("Refresh Preview", function()
                self:RefreshCharacterPreview()
            end)
            right:AddButton("Show Notification", function()
                self:Notify("Settings tab working")
            end)
            right:AddLabel("Sin opciones duplicadas.")
        end

        combatTab:Show()
        self:ApplySearch("")
        self:SetAccent(Theme.Accent)
        self:ApplyBottomTabsVisible(true)
        self:ApplyBlurEnabled(true)
        self:ApplyUIScale(1)
        self:ApplyVisualPreset("Default")
        self:UpdateCombatOverlay()
        self:ApplyPreviewVisible(true)
    end

    self:BuildDemo()
    return self
end

return Library
