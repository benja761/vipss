local function RelayoutNotifications()
    for i, n in ipairs(notifications) do
        local y = -((i - 1) * 56)
        if n.card.Parent then
            Tween(n.card, TweenInfo.new(0.15), {Position = UDim2.new(1, 0, 1, y)})
