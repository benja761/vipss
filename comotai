                        BorderSizePixel = 0,
                        Size = UDim2.new(0, 0, 1, 0),
                    })
                    Corner(fill, 999)
                    self.ParentWindow:RegisterAccentObject(fill, "bg")

                    local knob = Create("Frame", {
                        Parent = bar,
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(0, 0, 0.5, 0),
                        Size = UDim2.new(0, 14, 0, 14),
                        BackgroundColor3 = Theme.Text,
                        BorderSizePixel = 0,
                        ZIndex = 3,
                    })
                    Corner(knob, 999)

                    local dragging = false
                    local value = default or min

                    local function setValueFromPct(pct)
                        pct = math.clamp(pct, 0, 1)
                        value = math.floor((min + (max - min) * pct) * 10 + 0.5) / 10
                        valueLabel.Text = tostring(value)
                        fill.Size = UDim2.new(pct, 0, 1, 0)
                        knob.Position = UDim2.new(pct, 0, 0.5, 0)
                        if callback then
                            callback(value)
                        end
                    end

                    if max == min then
                        setValueFromPct(0)
                    else
                        setValueFromPct((value - min) / (max - min))
                    end

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            local pct = (input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                            setValueFromPct(pct)
                        end
                    end)

                    UIS.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            local pct = (input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                            setValueFromPct(pct)
                        end
                    end)

                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = false
                        end
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return value
                        end
                    }
                end

