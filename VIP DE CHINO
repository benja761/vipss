    function self:ApplySearch(query)
        query = string.lower(query or "")

        for _, tab in ipairs(self.Tabs) do
            local activeTab = (self.CurrentTab == tab)

            for _, sub in ipairs(tab.SubTabs) do
                local activeSub = (tab.CurrentSub == sub)
                local anySectionVisible = false

                for _, section in ipairs(sub.Sections) do
                    local visibleChildren = 0

                    for _, item in ipairs(section.Items) do
                        local ok = (query == "") or string.find(item.Search, query, 1, true) ~= nil
                        item.Root.Visible = ok and activeTab and activeSub
                        if item.Root.Visible then
                            visibleChildren = visibleChildren + 1
                        end
                    end

                    section.Root.Visible = (visibleChildren > 0) and activeTab and activeSub
                    if section.Root.Visible then
                        anySectionVisible = true
                    end
                end

                sub.Page.Visible = activeTab and activeSub
                if not anySectionVisible and query ~= "" then
                    sub.Page.Visible = activeTab and activeSub
                end
            end
        end
    end

