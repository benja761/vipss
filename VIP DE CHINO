                        BackgroundColor3 = Theme.White,
                        BorderSizePixel = 0,
                    })
                    Corner(knob, 99)
                    Stroke(knob, Theme.Accent, 1)

                    local value = default or min
                    local dragging = false

                    local function setFromX(x)
                        local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                        value = min + (max - min) * pct

                        if math.floor(min) == min and math.floor(max) == max then
                            value = math.floor(value + 0.5)
                        else
                            value = math.floor(value * 100 + 0.5) / 100
                        end

                        valueLbl.Text = tostring(value)
                        fill.Size = UDim2.new(pct, 0, 1, 0)
                        knob.Position = UDim2.new(pct, 0, 0.5, 0)

                        if callback then
                            callback(value)
                        end
                    end

                    local defaultPct = (value - min) / (max - min)
                    fill.Size = UDim2.new(defaultPct, 0, 1, 0)
                    knob.Position = UDim2.new(defaultPct, 0, 0.5, 0)

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            setFromX(input.Position.X)
                        end
                    end)

                    UIS.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            setFromX(input.Position.X)
                        end
                    end)

                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = false
                        end
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return value
                        end,
                        Set = function(_, v)
                            local pct = (v - min) / (max - min)
                            pct = math.clamp(pct, 0, 1)
                            setFromX(bar.AbsolutePosition.X + (bar.AbsoluteSize.X * pct))
                        end
                    }
