    function self:ApplySearch(query)
        query = string.lower(query or "")
        for _, tab in ipairs(self.Tabs) do
            local active = (self.CurrentTab == tab)
            for _, sub in ipairs(tab.SubTabs) do
                local isSubActive = active and (tab.CurrentSub == sub)
                local visibleCount = 0

                for _, section in ipairs(sub.Sections) do
                    local sectionVisible = 0
                    for _, item in ipairs(section.Items) do
                        local match = (query == "") or string.find(item.Search, query, 1, true)
                        item.Root.Visible = match and isSubActive
                        if item.Root.Visible then
                            sectionVisible += 1
                        end
                    end
                    section.Root.Visible = sectionVisible > 0 and isSubActive
                    if section.Root.Visible then
                        visibleCount += 1
                    end
                end

                sub.Page.Visible = isSubActive
            end
        end
    end

