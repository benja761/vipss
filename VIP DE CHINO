    function self:SaveConfig(name)
        local payload = {
            ThemeAccent = serializeColor3(Theme.Accent),
            Flags = self.Flags,
            MenuKeybind = self.MenuKeybind.Name
        }
        self._configs[name] = HttpService:JSONEncode(payload)
    end

    function self:LoadConfig(name)
        local raw = self._configs[name]
        if not raw then
            return false
        end

        local data = HttpService:JSONDecode(raw)
        if data.ThemeAccent then
            Theme.Accent = deserializeColor3(data.ThemeAccent)
            self:UpdateAccentVisuals()
        end
        if data.Flags then
            self.Flags = data.Flags
        end
        if data.MenuKeybind and Enum.KeyCode[data.MenuKeybind] then
            self.MenuKeybind = Enum.KeyCode[data.MenuKeybind]
        end
        return true
    end

