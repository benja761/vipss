                        TextColor3 = Theme.Text,
                        TextSize = 13,
                        AutoButtonColor = false,
                    })
                    Corner(button, 6)
                    local btnStroke = Stroke(button, Theme.Border, 1)
                    setHover(button, Theme.Element, Theme.ElementHover, btnStroke)

                    local listHolder = Create("Frame", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 38),
                        Size = UDim2.new(1, 0, 0, 0),
                    })
                    Create("UIListLayout", {
                        Parent = listHolder,
                        Padding = UDim.new(0, 4),
                    })

                    local current = default
                    local open = false
                    for _, option in ipairs(items or {}) do
                        local opt = Create("TextButton", {
                            Parent = listHolder,
                            BackgroundColor3 = Theme.Element,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 28),
                            Text = tostring(option),
                            Font = Enum.Font.Gotham,
                            TextColor3 = Theme.Text,
                            TextSize = 13,
                            AutoButtonColor = false,
                        })
                        Corner(opt, 6)
                        local os = Stroke(opt, Theme.Border, 1)
                        setHover(opt, Theme.Element, Theme.ElementHover, os)
                        opt.MouseButton1Click:Connect(function()
                            current = option
                            button.Text = "  " .. tostring(option)
                            open = false
                            Tween(listHolder, 0.15, {Size = UDim2.new(1, 0, 0, 0)})
                            Tween(wrap, 0.15, {Size = UDim2.new(1, 0, 0, 34)})
                            if callback then callback(option) end
                        end)
                    end

                    button.MouseButton1Click:Connect(function()
                        open = not open
                        local height = #(items or {}) * 32
                        Tween(listHolder, 0.15, {Size = open and UDim2.new(1, 0, 0, height) or UDim2.new(1, 0, 0, 0)})
                        Tween(wrap, 0.15, {Size = open and UDim2.new(1, 0, 0, 38 + height) or UDim2.new(1, 0, 0, 34)})
                    end)

                    register(wrap, text)
                    return {Get = function() return current end}
                end

                function Section:AddKeybind(text, defaultKey, callback)
                    local currentKey = defaultKey or Enum.KeyCode.Z
                    local waiting = false

                    local btn = Section:AddButton(text .. ": " .. currentKey.Name, function()
                        waiting = true
                        btn.Text = text .. ": ..."
                    end)

                    UIS.InputBegan:Connect(function(input, gp)
                        if gp or not waiting then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            waiting = false
                            currentKey = input.KeyCode
                            btn.Text = text .. ": " .. currentKey.Name
                            if callback then callback(currentKey) end
                        end
                    end)

                    return {
                        Get = function() return currentKey end,
                    }
                end

                function Section:AddColorPicker(text, defaultColor, callback, applyToAccent)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 34),
                        ClipsDescendants = true,
                    })

                    local button = Create("TextButton", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 34),
                        Text = "",
                        AutoButtonColor = false,
                    })
                    Corner(button, 6)
                    local bStroke = Stroke(button, Theme.Border, 1)
                    setHover(button, Theme.Element, Theme.ElementHover, bStroke)

                    Create("TextLabel", {
                        Parent = button,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 10, 0, 0),
                        Size = UDim2.new(1, -48, 1, 0),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = text,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local preview = Create("Frame", {
                        Parent = button,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, -8, 0.5, 0),
                        Size = UDim2.new(0, 20, 0, 20),
                        BackgroundColor3 = defaultColor or Theme.Accent,
                        BorderSizePixel = 0,
                    })
                    Corner(preview, 5)
                    Stroke(preview, Theme.Border, 1)

                    local panel = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Panel2,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 38),
                        Size = UDim2.new(1, 0, 0, 0),
                        ClipsDescendants = true,
                    })
                    Corner(panel, 8)
                    Stroke(panel, Theme.Border, 1)
                    local pad = Padding(panel, 10, 10, 10, 10)
                    pad.Parent = panel

                    local hueSlider = Create("Frame", {
                        Parent = panel,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 12),
                    })
                    Corner(hueSlider, 999)
                    Stroke(hueSlider, Theme.Border, 1)

                    local hueFill = Create("UIGradient")
                    hueFill.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0.0, Color3.fromRGB(255, 0, 0)),
                        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                        ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
                        ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                        ColorSequenceKeypoint.new(1.0, Color3.fromRGB(255, 0, 0)),
                    })
                    hueFill.Parent = hueSlider

                    local satSlider = Create("Frame", {
                        Parent = panel,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 28),
                        Size = UDim2.new(1, 0, 0, 12),
                    })
                    Corner(satSlider, 999)
                    Stroke(satSlider, Theme.Border, 1)

                    local valSlider = Create("Frame", {
                        Parent = panel,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 56),
                        Size = UDim2.new(1, 0, 0, 12),
                    })
                    Corner(valSlider, 999)
                    Stroke(valSlider, Theme.Border, 1)

                    local current = defaultColor or Theme.Accent
                    local h, s, v = current:ToHSV()
                    local open = false

                    local function updateColor()
                        local c = Color3.fromHSV(h, s, v)
                        preview.BackgroundColor3 = c
                        if callback then callback(c) end
                        if applyToAccent then
                            self.ParentWindow:SetAccent(c)
                        end
                    end

                    local function bindSlider(slider, getter, setter)
                        local dragging = false
                        slider.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                dragging = true
                                local pct = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
                                setter(pct)
                            end
                        end)
                        UIS.InputChanged:Connect(function(input)
                            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                                local pct = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
                                setter(pct)
                            end
                        end)
                        UIS.InputEnded:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                dragging = false
                            end
                        end)
                    end

                    bindSlider(hueSlider, function() return h end, function(p) h = p updateColor() end)
                    bindSlider(satSlider, function() return s end, function(p) s = p updateColor() end)
                    bindSlider(valSlider, function() return v end, function(p) v = p updateColor() end)

                    button.MouseButton1Click:Connect(function()
                        open = not open
                        Tween(panel, 0.15, {Size = open and UDim2.new(1, 0, 0, 78) or UDim2.new(1, 0, 0, 0)})
                        Tween(wrap, 0.15, {Size = open and UDim2.new(1, 0, 0, 120) or UDim2.new(1, 0, 0, 34)})
                    end)

                    updateColor()

                    table.insert(self.ParentWindow.ColorPickers, {
                        Preview = preview,
                        ApplyToAccent = applyToAccent,
                    })

                    register(wrap, text)
                    return {
                        Get = function() return preview.BackgroundColor3 end,
                    }
                end

                table.insert(self.Sections, Section)
                return Section
            end

            Sub.ParentWindow = self
            subButton.MouseButton1Click:Connect(function()
                playPop()
                Sub:Show()
            end)

            table.insert(Tab.SubTabs, Sub)
            if not Tab.CurrentSub then
                Tab.CurrentSub = Sub
            end
            return Sub
        end

        function Tab:Show()
            for _, t in ipairs(self.ParentWindow.Tabs) do
                Tween(t.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                local tStroke = t.Button:FindFirstChildOfClass("UIStroke")
                if tStroke then Tween(tStroke, 0.12, {Color = Theme.Border}) end
                t.Button.TextColor3 = Theme.SubText
                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    if s.Button then
                        s.Button.Visible = false
                        s.Button.Parent = subTabsScroll
                    end
                end
            end

            Tween(self.Button, 0.12, {BackgroundColor3 = Theme.Element})
            local activeStroke = self.Button:FindFirstChildOfClass("UIStroke")
            if activeStroke then Tween(activeStroke, 0.12, {Color = Theme.Accent}) end
            self.Button.TextColor3 = Theme.Text

            self.ParentWindow.CurrentTab = self

            subTabHolder.Visible = #self.SubTabs > 0 and pages.Visible
            for _, s in ipairs(self.SubTabs) do
                if s.Button then
                    s.Button.Visible = true
                    s.Button.Parent = subTabsScroll
                end
            end

            if self.CurrentSub then
                self.CurrentSub:Show()
            end
        end

        tabButton.MouseButton1Click:Connect(function()
            playPop()
            Tab:Show()
        end)

        Tab.ParentWindow = self
        table.insert(self.Tabs, Tab)
        return Tab
    end

    function self:CreatePreviewPanel()
        if self.PreviewPanel and self.PreviewPanel.Parent then
            self.PreviewPanel.Visible = true
            return
        end

        local preview = Create("Frame", {
            Parent = main,
            BackgroundColor3 = Theme.Panel,
            Size = UDim2.new(0, 170, 0, 320),
            Position = UDim2.new(1, 12, 0, 96),
            ZIndex = 4,
        })
        makeGlow(preview, 3)
        Corner(preview, 8)
        Stroke(preview, Theme.Border, 1)

        Create("TextLabel", {
            Parent = preview,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 10, 0, 8),
            Size = UDim2.new(1, -20, 0, 18),
            Text = "Character Preview",
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextColor3 = Theme.Text,
            TextSize = 12,
        })

        local viewport = Create("ViewportFrame", {
            Parent = preview,
            BackgroundColor3 = Theme.Main2,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 8, 0, 34),
            Size = UDim2.new(1, -16, 1, -42),
        })
        Corner(viewport, 6)
        Stroke(viewport, Theme.Border, 1)

        local clone = cloneCharacter(viewport)
        local conn = RunService.RenderStepped:Connect(function(dt)
            if clone and clone.Parent and clone.PrimaryPart then
                clone:PivotTo(clone:GetPivot() * CFrame.Angles(0, math.rad(16 * dt), 0))
            end
        end)

        LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.7)
            clone = cloneCharacter(viewport)
        end)

        self.PreviewPanel = preview
        self.PreviewConn = conn
    end

    function self:BuildDemo()
        playPop()
        self:Notify("UI loaded successfully")

        local mainTab = self:AddTab("Main")
        local combatTab = self:AddTab("Combat")
        local visualsTab = self:AddTab("Visuals")
        local playerTab = self:AddTab("Player")
        local settingsTab = self:AddTab("Settings")

        local dashboard = mainTab:AddSubTab("Dashboard")
        do
            local left = dashboard:AddSection("Welcome", "left")
            left:AddLabel("Valary-style safe menu for your Roblox Studio game.")
            left:AddButton("Show Notification", function()
                self:Notify("Everything is working")
            end)

            local right = dashboard:AddSection("Quick Options", "right")
            right:AddToggle("Show Intro Effects", true)
            right:AddSlider("UI Animation Speed", 0.05, 1, 0.18)
        end

        local selector = combatTab:AddSubTab("Selector")
        do
            local left = selector:AddSection("Selector Settings", "left")
            left:AddSlider("FOV Radius", 20, 400, 120)
            left:AddToggle("Ignore Friends", false)
            left:AddToggle("Draw FOV Circle", true)

            local right = selector:AddSection("Extra", "right")
            right:AddToggle("Visible Check", false)
            right:AddToggle("Distance Check", false)
            right:AddSlider("Max Distance", 50, 1000, 350)
        end

        local world = visualsTab:AddSubTab("World")
        do
            local left = world:AddSection("World Settings", "left")
            left:AddToggle("Ambient Enabled", false)
            left:AddColorPicker("Ambient Color", Theme.Accent)
            left:AddSlider("Brightness", 0, 10, 2)

            local right = world:AddSection("Camera", "right")
            right:AddSlider("Field Of View", 40, 120, 70)
            right:AddToggle("Fullbright", false)
        end

        local players = visualsTab:AddSubTab("Players")
        do
            local left = players:AddSection("Player ESP Style", "left")
            left:AddToggle("Show Character Preview", false, function(v)
                if v then
                    self:CreatePreviewPanel()
                    if self.PreviewPanel then self.PreviewPanel.Visible = true end
                else
                    if self.PreviewPanel then self.PreviewPanel.Visible = false end
                end
            end)
            left:AddToggle("Enabled", false)
            left:AddDropdown("Box Type", {"Corner", "2D", "3D"}, "Corner")
            left:AddSlider("Rotation", 0, 180, 90)
            left:AddColorPicker("Box Color", Theme.White)
            left:AddColorPicker("Fill Color", Theme.Accent)
            left:AddColorPicker("Healthbar Color", Color3.fromRGB(0, 255, 0))

            local right = players:AddSection("Labels", "right")
            right:AddToggle("Name", true)
            right:AddSlider("Name Size", 8, 24, 13)
            right:AddToggle("Distance", false)
            right:AddSlider("Distance Size", 8, 24, 11)
            right:AddToggle("Weapon", false)
            right:AddSlider("Weapon Size", 8, 24, 11)
        end

        local movement = playerTab:AddSubTab("Movement")
        do
            local left = movement:AddSection("Local Player", "left")
            left:AddSlider("Walk Speed", 8, 40, 16)
            left:AddSlider("Jump Power", 20, 120, 50)
            left:AddToggle("Infinite Stamina", false)

            local right = movement:AddSection("Character", "right")
            right:AddToggle("Fly Visual Toggle", false)
            right:AddButton("Refresh Character", function()
                self:Notify("Character refreshed")
            end)
        end

        local configs = settingsTab:AddSubTab("Configs")
        do
            local left = configs:AddSection("Menu", "left")
            left:AddKeybind("Hide Menu Key", Enum.KeyCode.Z, function(key)
                self.HideKey = key
                self:Notify("Hide key: " .. key.Name)
            end)
            left:AddToggle("Notifications", true)
            left:AddButton("Unload UI", function()
                if self.PreviewConn then self.PreviewConn:Disconnect() end
                if self.Blur then self.Blur:Destroy() end
                self.GUI:Destroy()
            end)

            local right = configs:AddSection("Theme", "right")
            right:AddColorPicker("Title Accent Color", Theme.Accent, function(c)
                self:SetAccent(c)
            end, true)
            right:AddDropdown("Theme Preset", {"Purple", "Blue", "Green", "Red"}, "Purple", function(v)
                if v == "Purple" then self:SetAccent(Color3.fromRGB(170, 85, 255)) end
                if v == "Blue" then self:SetAccent(Color3.fromRGB(0, 170, 255)) end
                if v == "Green" then self:SetAccent(Color3.fromRGB(0, 255, 140)) end
                if v == "Red" then self:SetAccent(Color3.fromRGB(255, 70, 70)) end
            end)
        end

        mainTab:Show()
    end

    return self
end

return Library
