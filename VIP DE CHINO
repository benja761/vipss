                function Section:AddLabel(text, color)
                    local lbl = Create("TextLabel", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 18),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextWrapped = true,
                        AutomaticSize = Enum.AutomaticSize.Y,
                        Text = text,
                        TextColor3 = color or Theme.Text,
                        TextSize = 13,
                    })
                    register(lbl, text)
                    return lbl
                end

                function Section:AddToggle(text, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 24),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, -36, 1, 0),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = text,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local btn = Create("TextButton", {
                        Parent = wrap,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, 0, 0.5, 0),
                        Size = UDim2.new(0, 22, 0, 22),
                        BackgroundColor3 = Theme.Element,
                        Text = "",
                        AutoButtonColor = false,
                    })
                    Corner(btn, 5)
                    local st = Stroke(btn, Theme.Border, 1)

                    local fill = Create("Frame", {
                        Parent = btn,
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(0.5, 0, 0.5, 0),
                        Size = UDim2.new(0, 0, 0, 0),
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                    })
                    Corner(fill, 4)

                    local state = default and true or false

                    local function render()
                        Tween(st, 0.12, {Color = state and Theme.Accent or Theme.Border})
                        Tween(fill, 0.12, {
                            Size = state and UDim2.new(1, -4, 1, -4) or UDim2.new(0, 0, 0, 0)
                        })
                    end

                    render()

                    btn.MouseButton1Click:Connect(function()
                        state = not state
                        render()
                        if callback then
                            callback(state)
                        end
                    end)

                    register(wrap, text)
                    return {
                        Set = function(_, v)
                            state = v
                            render()
                        end,
                        Get = function()
                            return state
                        end
                    }
                end

                function Section:AddSlider(text, min, max, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 42),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 0),
                        Size = UDim2.new(0.75, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local valueLbl = Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0.75, 0, 0, 0),
                        Size = UDim2.new(0.25, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = tostring(default),
                        TextXAlignment = Enum.TextXAlignment.Right,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local bar = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 22),
                        Size = UDim2.new(1, 0, 0, 14),
                    })
                    Corner(bar, 4)
                    Stroke(bar, Theme.Border, 1)

                    local fill = Create("Frame", {
                        Parent = bar,
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                        Size = UDim2.new(0, 0, 1, 0),
                    })
                    Corner(fill, 4)

                    local value = default or min
                    local draggingSlider = false

                    local function setFromX(x)
                        local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                        value = math.floor((min + (max - min) * pct) * 10 + 0.5) / 10
                        valueLbl.Text = tostring(value)
                        fill.Size = UDim2.new(pct, 0, 1, 0)
                        if callback then
                            callback(value)
                        end
                    end

                    task.defer(function()
                        local denom = (max - min)
                        local pct = denom ~= 0 and ((value - min) / denom) or 0
                        fill.Size = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)
                    end)

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            draggingSlider = true
                            setFromX(input.Position.X)
                        end
                    end)

                    UIS.InputChanged:Connect(function(input)
                        if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                            setFromX(input.Position.X)
                        end
                    end)

                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            draggingSlider = false
                        end
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return value
                        end
                    }
                end

                function Section:AddDropdown(text, items, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 32),
                        ClipsDescendants = true,
                    })

                    local btn = Create("TextButton", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 32),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = "  " .. tostring(default or "--"),
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                        AutoButtonColor = false,
                    })
                    Corner(btn, 5)
                    local st = Stroke(btn, Theme.Border, 1)
                    hoverFrame(btn, Theme.Element, Theme.Panel2, st)

                    local open = false
                    local listHolder = Create("Frame", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 36),
                        Size = UDim2.new(1, 0, 0, 0),
                    })

                    Create("UIListLayout", {
                        Parent = listHolder,
                        Padding = UDim.new(0, 4)
                    })

                    local current = default

                    for _, option in ipairs(items or {}) do
                        local opt = Create("TextButton", {
                            Parent = listHolder,
                            BackgroundColor3 = Theme.Element,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 28),
                            Text = tostring(option),
                            Font = Enum.Font.Gotham,
                            TextColor3 = Theme.Text,
                            TextSize = 13,
                            AutoButtonColor = false,
                        })
                        Corner(opt, 5)
                        local os = Stroke(opt, Theme.Border, 1)
                        hoverFrame(opt, Theme.Element, Theme.Panel2, os)

                        opt.MouseButton1Click:Connect(function()
                            current = option
                            btn.Text = "  " .. tostring(option)
                            open = false
                            Tween(listHolder, 0.15, {Size = UDim2.new(1, 0, 0, 0)})
                            Tween(wrap, 0.15, {Size = UDim2.new(1, 0, 0, 32)})
                            if callback then
                                callback(option)
                            end
                        end)
                    end

                    btn.MouseButton1Click:Connect(function()
                        open = not open
                        local full = (#(items or {}) * 32)
                        Tween(listHolder, 0.15, {
                            Size = open and UDim2.new(1, 0, 0, full) or UDim2.new(1, 0, 0, 0)
                        })
                        Tween(wrap, 0.15, {
                            Size = open and UDim2.new(1, 0, 0, 36 + full) or UDim2.new(1, 0, 0, 32)
                        })
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return current
                        end
                    }
                end

                function Section:AddTextbox(text, placeholder, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 52),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local box = Create("TextBox", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 22),
                        Size = UDim2.new(1, 0, 0, 28),
                        Font = Enum.Font.Gotham,
                        PlaceholderText = placeholder or "type here...",
                        Text = "",
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        PlaceholderColor3 = Theme.SubText,
                        TextSize = 13,
                        ClearTextOnFocus = false,
                    })
                    Corner(box, 5)
                    local st = Stroke(box, Theme.Border, 1)
                    hoverFrame(box, Theme.Element, Theme.Panel2, st)

                    box.FocusLost:Connect(function()
                        if callback then
                            callback(box.Text)
                        end
                    end)

                    register(wrap, text)
                    return box
                end

                function Section:AddColorChipRow(text, colors)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 24),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0.6, 0, 1, 0),
                        Font = Enum.Font.Gotham,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    for i = #colors, 1, -1 do
                        local chip = Create("Frame", {
                            Parent = wrap,
                            AnchorPoint = Vector2.new(1, 0.5),
                            Position = UDim2.new(1, -((#colors - i) * 25), 0.5, 0),
                            Size = UDim2.new(0, 20, 0, 20),
                            BackgroundColor3 = colors[i],
                            BorderSizePixel = 0,
                        })
                        Corner(chip, 4)
                        Stroke(chip, Theme.Border, 1)
                    end

                    register(wrap, text)
                    return wrap
                end

                table.insert(self.Sections, Section)
                return Section
            end

            Sub.ParentWindow = self
            table.insert(Tab.SubTabs, Sub)

            if not Tab.CurrentSub then
                Tab.CurrentSub = Sub
            end

            return Sub
        end

        function Tab:Show()
            for _, t in pairs(self.ParentWindow.Tabs) do
                Tween(t.Button, 0.12, {BackgroundColor3 = Theme.Panel})

                local tabStrokeObj = t.Button:FindFirstChildOfClass("UIStroke")
                if tabStrokeObj then
                    Tween(tabStrokeObj, 0.12, {Color = Theme.Border})
                end

                t.Button.TextColor3 = Theme.SubText

                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    if s.Button then
                        s.Button.Visible = false
                        Tween(s.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                        local subStrokeObj = s.Button:FindFirstChildOfClass("UIStroke")
                        if subStrokeObj then
                            Tween(subStrokeObj, 0.12, {Color = Theme.Border})
                        end
                    end
                end
            end

            Tween(self.Button, 0.12, {BackgroundColor3 = Theme.Element})

            local activeStroke = self.Button:FindFirstChildOfClass("UIStroke")
            if activeStroke then
                Tween(activeStroke, 0.12, {Color = Theme.Accent})
            end

            self.Button.TextColor3 = Theme.Text
            self.ParentWindow.CurrentTab = self
            subTabHolder.Visible = #self.SubTabs > 0

            for _, s in ipairs(self.SubTabs) do
                if s.Button then
                    s.Button.Visible = true
                end
            end

            if self.CurrentSub then
                self.CurrentSub:Show()
            end
        end

        Tab.ParentWindow = self
        tabButton.MouseButton1Click:Connect(function()
            Tab:Show()
        end)

        table.insert(self.Tabs, Tab)
        return Tab
    end

    task.defer(function()
        self:Notify("UI loaded successfully")
    end)

    return self
end

