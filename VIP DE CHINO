    function self:ApplySearch(query)
        query = string.lower(query or "")

        for _, tab in ipairs(self.Tabs) do
            local active = self.CurrentTab == tab

            for _, sub in ipairs(tab.SubTabs) do
                for _, section in ipairs(sub.Sections) do
                    local visibleChildren = 0

                    for _, item in ipairs(section.Items) do
                        local ok = (query == "") or string.find(item.Search, query, 1, true)
                        item.Root.Visible = ok and active and (sub == tab.CurrentSub)
                        if item.Root.Visible then
                            visibleChildren += 1
                        end
                    end

                    section.Root.Visible = visibleChildren > 0 and active and (sub == tab.CurrentSub)
                end

                sub.Page.Visible = active and (sub == tab.CurrentSub)
            end
        end
    end

