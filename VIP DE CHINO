            table.insert(Tab.SubTabs, Sub)
            if not Tab.CurrentSub then
                Tab.CurrentSub = Sub
            end
            return Sub
        end

        function Tab:Show()
            for _, t in ipairs(self.ParentWindow.Tabs) do
                Tween(t.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                local tabSt = t.Button:FindFirstChildOfClass("UIStroke")
                if tabSt then
                    Tween(tabSt, 0.12, {Color = Theme.Border})
                end
                t.Button.TextColor3 = Theme.SubText

                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    if s.Button then
                        s.Button.Visible = false
                    end
                end
            end

            Tween(self.Button, 0.12, {BackgroundColor3 = Theme.Element})
            local activeStroke = self.Button:FindFirstChildOfClass("UIStroke")
            if activeStroke then
                Tween(activeStroke, 0.12, {Color = Theme.Accent})
            end
            self.Button.TextColor3 = Theme.Text

            self.ParentWindow.CurrentTab = self
            subTabHolder.Visible = (not self.ParentWindow.Minimized) and (#self.SubTabs > 0) or false

            for _, s in ipairs(self.SubTabs) do
                if s.Button then
                    s.Button.Visible = true
                    s.Button.Parent = subTabHolder
                end
            end

            if self.CurrentSub then
                self.CurrentSub:Show()
            end

            self.ParentWindow.PlayPop(1.01, 0.14)
        end

        tabButton.MouseButton1Click:Connect(function()
            Tab:Show()
        end)

        table.insert(self.Tabs, Tab)
        return Tab
    end

    task.defer(function()
        self:Notify("UI loaded successfully")
        self.PlayPop(1.08, 0.22)
    end)

    return self
end

