                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local switch = Create("TextButton", {
                        Parent = wrap,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, 0, 0.5, 0),
                        Size = UDim2.new(0, 42, 0, 22),
                        BackgroundColor3 = Theme.Element,
                        Text = "",
                        AutoButtonColor = false,
                    })
                    Corner(switch, 999)
                    local swStroke = Stroke(switch, Theme.Border, 1)

                    local knob = Create("Frame", {
                        Parent = switch,
                        Size = UDim2.new(0, 16, 0, 16),
                        Position = UDim2.new(0, 3, 0.5, -8),
                        BackgroundColor3 = Theme.Text,
                        BorderSizePixel = 0,
                    })
                    Corner(knob, 999)

                    local state = default and true or false
                    local function render()
                        Tween(swStroke, 0.12, {Color = state and Theme.Accent or Theme.Border})
                        Tween(switch, 0.12, {BackgroundColor3 = state and Theme.AccentDark or Theme.Element})
                        Tween(knob, 0.12, {Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)})
                    end
                    render()

                    switch.MouseButton1Click:Connect(function()
                        state = not state
                        render()
                        if callback then callback(state) end
                    end)

                    register(wrap, text)
                    return {
                        Get = function() return state end,
                        Set = function(_, v)
                            state = v and true or false
                            render()
                        end,
                    }
                end

                function Section:AddSlider(text, min, max, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 44),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 0),
                        Size = UDim2.new(0.7, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local valueLabel = Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0.7, 0, 0, 0),
                        Size = UDim2.new(0.3, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        TextXAlignment = Enum.TextXAlignment.Right,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local bar = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 24),
                        Size = UDim2.new(1, 0, 0, 10),
                    })
                    Corner(bar, 999)
                    Stroke(bar, Theme.Border, 1)

                    local fill = Create("Frame", {
                        Parent = bar,
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                        Size = UDim2.new(0, 0, 1, 0),
                    })
                    Corner(fill, 999)

                    local knob = Create("Frame", {
                        Parent = bar,
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(0, 0, 0.5, 0),
                        Size = UDim2.new(0, 14, 0, 14),
                        BackgroundColor3 = Theme.Text,
                        BorderSizePixel = 0,
                        ZIndex = 3,
                    })
                    Corner(knob, 999)

                    local dragging = false
                    local value = default or min

                    local function setValueFromPct(pct)
                        pct = math.clamp(pct, 0, 1)
                        value = math.floor((min + (max - min) * pct) * 10 + 0.5) / 10
                        valueLabel.Text = tostring(value)
                        fill.Size = UDim2.new(pct, 0, 1, 0)
                        knob.Position = UDim2.new(pct, 0, 0.5, 0)
                        if callback then callback(value) end
                    end

                    setValueFromPct((value - min) / (max - min))

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            local pct = (input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                            setValueFromPct(pct)
                        end
                    end)

                    UIS.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            local pct = (input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
                            setValueFromPct(pct)
                        end
                    end)

                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = false
                        end
                    end)

                    register(wrap, text)
                    return {Get = function() return value end}
                end

                function Section:AddDropdown(text, items, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 34),
                        ClipsDescendants = true,
                    })

                    local button = Create("TextButton", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 34),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
