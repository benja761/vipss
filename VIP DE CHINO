        function Tab:Show()
            for _, t in ipairs(self.ParentWindow.Tabs) do
                Tween(t.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                local st = t.Button:FindFirstChildOfClass("UIStroke")
                if st then Tween(st, 0.12, {Color = Theme.Border}) end
                t.Button.TextColor3 = Theme.SubText
                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    s.Button.Visible = false
                    Tween(s.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                    local sst = s.Button:FindFirstChildOfClass("UIStroke")
                    if sst then Tween(sst, 0.12, {Color = Theme.Border}) end
                end
            end
            Tween(self.Button, 0.12, {BackgroundColor3 = Theme.Element})
            local st = self.Button:FindFirstChildOfClass("UIStroke")
            if st then Tween(st, 0.12, {Color = Theme.Accent}) end
            self.Button.TextColor3 = Theme.Text
            self.ParentWindow.CurrentTab = self
            subTabHolder.Visible = #self.SubTabs > 0
            for _, s in ipairs(self.SubTabs) do
                s.Button.Parent = subTabsScroll
                s.Button.Visible = true
            end
            if self.CurrentSub then self.CurrentSub:Show() end
            self.ParentWindow:PlayPop()
        end

        tabButton.MouseButton1Click:Connect(function() Tab:Show() end)
        table.insert(self.Tabs, Tab)
        return Tab
    end

