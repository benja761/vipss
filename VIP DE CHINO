        if self.PreviewConn then self.PreviewConn:Disconnect() end
        self.PreviewConn = RunService.RenderStepped:Connect(function(dt)
            if clone and clone.Parent and clone.PrimaryPart then
                clone:PivotTo(clone:GetPivot() * CFrame.Angles(0, math.rad(18 * dt), 0))
            end
        end)

        LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.8)
            clone = cloneCharacter(viewport)
        end)

        self.PreviewPanel = preview
    end

