        l:AddButton("Load Settings", function()
            local name = configName.Text ~= "" and configName.Text or "default"
            local ok = window:LoadConfig(name)
            window:Notify(ok and ("Settings loaded: " .. name) or ("No config found: " .. name))
        end)

        l:AddButton("Reset Settings", function()
            window.Flags = {}
            window:Notify("Settings reset")
        end)

        local r = cfg:AddSection("Menu Settings", "right")
        r:AddDropdown("Tweening Style", {"Quad", "Linear", "Cubic", "Quint"}, "Quad")
        r:AddDropdown("Direction", {"Out", "In", "InOut"}, "Out")
        r:AddSlider("Tween Time", 0.05, 1, 0.18)
        r:AddToggle("Watermark", false)
        r:AddToggle("Keybind List", false)
        r:AddToggle("Global Chat", false)
        r:AddButton("Unload UI", function()
            if window.PreviewConn then
                window.PreviewConn:Disconnect()
            end
            if window.Blur then
                window.Blur:Destroy()
            end
            if window.GUI then
                window.GUI:Destroy()
            end
        end)
    end

    local theming = settings:AddSubTab("Theming")
    do
        local l = theming:AddSection("Accent Presets", "left")
        l:AddButton("Purple", function()
            Theme.Accent = Color3.fromRGB(170, 85, 255)
            window:Notify("Accent changed to Purple")
        end)
        l:AddButton("Blue", function()
            Theme.Accent = Color3.fromRGB(0, 170, 255)
            window:Notify("Accent changed to Blue")
        end)
        l:AddButton("Green", function()
            Theme.Accent = Color3.fromRGB(0, 255, 140)
            window:Notify("Accent changed to Green")
        end)
        l:AddButton("Red", function()
            Theme.Accent = Color3.fromRGB(255, 34, 34)
            window:Notify("Accent changed to Red")
        end)

        local r = theming:AddSection("Interface", "right")
        r:AddToggle("Notifications", true)
        r:AddToggle("Blur Background", true)
        r:AddToggle("Show Preview Panel", true, function(v)
            if v then
                window:CreatePreviewPanel()
            else
                if window.PreviewPanel then
                    window.PreviewPanel.Visible = false
                end
            end
        end)
        r:AddDropdown("Theme", {"Dark Purple", "Blue", "Green", "Red"}, "Dark Purple")
    end

    main:Show()
end

return Library
