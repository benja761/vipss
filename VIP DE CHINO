                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, 0, 0.5, 0),
                        Size = UDim2.new(0, 22, 0, 22),
                        BackgroundColor3 = Theme.Element,
                        Text = "",
                        AutoButtonColor = false,
                    })
                    Corner(btn, 5)
                    local st = Stroke(btn, Theme.Border, 1)

                    local fill = Create("Frame", {
                        Parent = btn,
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(0.5, 0, 0.5, 0),
                        Size = UDim2.new(0, 0, 0, 0),
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                    })
                    Corner(fill, 4)

                    local state = default and true or false

                    local function render()
                        Tween(st, 0.12, {Color = state and Theme.Accent or Theme.Border})
                        Tween(fill, 0.12, {
                            Size = state and UDim2.new(1, -4, 1, -4) or UDim2.new(0, 0, 0, 0)
                        })
                    end

                    render()

                    btn.MouseButton1Click:Connect(function()
                        state = not state
                        render()
                        self.ParentWindow:PlayPop()
                        if callback then
                            callback(state)
                        end
                    end)

                    register(wrap, text)
                    return {
                        Set = function(_, v)
                            state = v
                            render()
                        end,
                        Get = function()
                            return state
                        end
                    }
                end

                function Section:AddSlider(text, min, max, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 42),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 0),
                        Size = UDim2.new(0.75, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local valueLbl = Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0.75, 0, 0, 0),
                        Size = UDim2.new(0.25, 0, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = tostring(default),
                        TextXAlignment = Enum.TextXAlignment.Right,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local bar = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 22),
                        Size = UDim2.new(1, 0, 0, 14),
                    })
                    Corner(bar, 4)
                    Stroke(bar, Theme.Border, 1)

                    local fill = Create("Frame", {
                        Parent = bar,
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                        Size = UDim2.new(0, 0, 1, 0),
                    })
                    Corner(fill, 4)

                    local value = default or min
                    local dragging = false

                    local function setFromX(x)
                        local pct = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                        value = math.floor((min + (max - min) * pct) * 10 + 0.5) / 10
                        valueLbl.Text = tostring(value)
                        fill.Size = UDim2.new(pct, 0, 1, 0)
                        if callback then
                            callback(value)
                        end
                    end

                    task.defer(function()
                        setFromX(bar.AbsolutePosition.X + (bar.AbsoluteSize.X * ((value - min) / (max - min))))
                    end)

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            setFromX(input.Position.X)
                            self.ParentWindow:PlayPop()
                        end
                    end)

                    UIS.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            setFromX(input.Position.X)
                        end
                    end)

                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = false
                        end
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return value
                        end
                    }
                end

                function Section:AddDropdown(text, items, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 32),
                        ClipsDescendants = true,
                    })

                    local btn = Create("TextButton", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 32),
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Text = "  " .. tostring(default or "--"),
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                        AutoButtonColor = false,
                    })
                    Corner(btn, 5)
                    local st = Stroke(btn, Theme.Border, 1)
                    hoverFrame(btn, Theme.Element, Theme.Panel2, st)

                    local open = false
                    local current = default

                    local listHolder = Create("Frame", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 36),
                        Size = UDim2.new(1, 0, 0, 0),
                    })

                    Create("UIListLayout", {
                        Parent = listHolder,
                        Padding = UDim.new(0, 4)
                    })

                    for _, option in ipairs(items or {}) do
                        local opt = Create("TextButton", {
                            Parent = listHolder,
                            BackgroundColor3 = Theme.Element,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 28),
                            Text = tostring(option),
                            Font = Enum.Font.Gotham,
                            TextColor3 = Theme.Text,
                            TextSize = 13,
                            AutoButtonColor = false,
                        })
                        Corner(opt, 5)
                        local os = Stroke(opt, Theme.Border, 1)
                        hoverFrame(opt, Theme.Element, Theme.Panel2, os)

                        opt.MouseButton1Click:Connect(function()
                            current = option
                            btn.Text = "  " .. tostring(option)
                            open = false
                            Tween(listHolder, 0.15, {Size = UDim2.new(1, 0, 0, 0)})
                            Tween(wrap, 0.15, {Size = UDim2.new(1, 0, 0, 32)})
                            self.ParentWindow:PlayPop()
                            if callback then
                                callback(option)
                            end
                        end)
                    end

                    btn.MouseButton1Click:Connect(function()
                        open = not open
                        local full = #(items or {}) * 32
                        Tween(listHolder, 0.15, {
                            Size = open and UDim2.new(1, 0, 0, full) or UDim2.new(1, 0, 0, 0)
                        })
                        Tween(wrap, 0.15, {
                            Size = open and UDim2.new(1, 0, 0, 36 + full) or UDim2.new(1, 0, 0, 32)
                        })
                        self.ParentWindow:PlayPop()
                    end)

                    register(wrap, text)
                    return {
                        Get = function()
                            return current
                        end
                    }
                end

                function Section:AddColorPicker(text, default, callback)
                    local colors = {
                        Color3.fromRGB(255, 0, 0),
                        Color3.fromRGB(255, 128, 0),
                        Color3.fromRGB(255, 255, 0),
                        Color3.fromRGB(0, 255, 0),
                        Color3.fromRGB(0, 170, 255),
                        Color3.fromRGB(170, 85, 255),
                        Color3.fromRGB(255, 255, 255),
                        Color3.fromRGB(0, 0, 0),
                    }

                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 56),
                    })

                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, -30, 0, 16),
                        Font = Enum.Font.GothamBold,
                        Text = text,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                    })

                    local preview = Create("Frame", {
                        Parent = wrap,
                        Position = UDim2.new(1, -22, 0, 0),
                        Size = UDim2.new(0, 18, 0, 18),
                        BackgroundColor3 = default or Theme.Accent,
                        BorderSizePixel = 0,
                    })
                    Corner(preview, 4)
                    Stroke(preview, Theme.Border, 1)

                    local row = Create("Frame", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 24),
                        Size = UDim2.new(1, 0, 0, 28),
                    })

                    local layout = Create("UIListLayout", {
                        Parent = row,
                        FillDirection = Enum.FillDirection.Horizontal,
                        Padding = UDim.new(0, 4),
                    })

                    local current = default or Theme.Accent

                    for _, col in ipairs(colors) do
                        local chip = Create("TextButton", {
                            Parent = row,
                            BackgroundColor3 = col,
                            Text = "",
                            AutoButtonColor = false,
                            Size = UDim2.new(0, 22, 0, 22),
                        })
                        Corner(chip, 4)
                        Stroke(chip, Theme.Border, 1)

                        chip.MouseButton1Click:Connect(function()
                            current = col
                            preview.BackgroundColor3 = col
                            self.ParentWindow:PlayPop()
                            if callback then
                                callback(col)
                            end
                        end)
                    end

                    register(wrap, text)
                    return {
                        Get = function()
                            return current
                        end
                    }
                end

                table.insert(self.Sections, Section)
                return Section
            end

            subButton.MouseButton1Click:Connect(function()
                Sub:Show()
            end)

            table.insert(Tab.SubTabs, Sub)
            if not Tab.CurrentSub then
                Tab.CurrentSub = Sub
            end

            return Sub
        end

        function Tab:Show()
            for _, t in ipairs(self.ParentWindow.Tabs) do
                Tween(t.Button, 0.12, {BackgroundColor3 = Theme.Panel})
                local tabStrokeObj = t.Button:FindFirstChildOfClass("UIStroke")
                if tabStrokeObj then
                    Tween(tabStrokeObj, 0.12, {Color = Theme.Border})
                end
                t.Button.TextColor3 = Theme.SubText

                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    if s.Button then
                        s.Button.Visible = false
                    end
                end
            end

            Tween(self.Button, 0.12, {BackgroundColor3 = Theme.Element})
            local activeStroke = self.Button:FindFirstChildOfClass("UIStroke")
            if activeStroke then
                Tween(activeStroke, 0.12, {Color = Theme.Accent})
            end

            self.Button.TextColor3 = Theme.Text
            self.ParentWindow.CurrentTab = self

            subTabHolder.Visible = #self.SubTabs > 0 and self.ParentWindow.MenuVisible

            for _, s in ipairs(self.SubTabs) do
                if s.Button then
                    s.Button.Visible = true
                end
            end

            self.ParentWindow:PlayPop()

            if self.CurrentSub then
                self.CurrentSub:Show()
            elseif self.SubTabs[1] then
                self.CurrentSub = self.SubTabs[1]
                self.CurrentSub:Show()
            end
        end

        tabButton.MouseButton1Click:Connect(function()
            Tab:Show()
        end)

        table.insert(self.Tabs, Tab)
        return Tab
    end

    close.MouseButton1Click:Connect(function()
        if self.PreviewConn then
            self.PreviewConn:Disconnect()
        end
        Tween(blur, 0.15, {Size = 0})
        task.delay(0.18, function()
            if blur then
                blur:Destroy()
            end
        end)
        gui:Destroy()
    end)

    local minimized = false
    mini.MouseButton1Click:Connect(function()
        minimized = not minimized

        Tween(main, 0.18, {
            Size = minimized and UDim2.new(0, 720, 0, 92) or UDim2.new(0, 720, 0, 480)
        })

        pages.Visible = not minimized
        searchFrame.Visible = not minimized

        if minimized then
            subTabHolder.Visible = false
            if self.PreviewPanel then
                self.PreviewPanel.Visible = false
            end
        else
            subTabHolder.Visible = self.CurrentTab and (#self.CurrentTab.SubTabs > 0) or false
        end

        self:PlayPop()
    end)

    UIS.InputBegan:Connect(function(input, gp)
        if gp then
            return
        end

        if input.KeyCode == self.HideKey then
            self.MenuVisible = not self.MenuVisible
            main.Visible = self.MenuVisible
            mainTabsHolder.Visible = self.MenuVisible
            subTabHolder.Visible = self.MenuVisible and self.CurrentTab and (#self.CurrentTab.SubTabs > 0) or false

            if self.PreviewPanel then
                self.PreviewPanel.Visible = self.MenuVisible and self.PreviewPanel.Visible
            end

            self:PlayPop()
        end
    end)

    main.Size = UDim2.new(0, 720, 0, 0)
    Tween(blur, 0.2, {Size = 4})
    Tween(main, 0.28, {Size = UDim2.new(0, 720, 0, 480)}, Enum.EasingStyle.Back)
    self:PlayPop()
    self:Notify("UI loaded successfully")

    return self
end

function Library:BuildDemo(window)
    local main = window:AddTab("Main")
    local visuals = window:AddTab("Visuals")
    local player = window:AddTab("Player")
    local settings = window:AddTab("Settings")

    local home = main:AddSubTab("Home")
    do
        local l = home:AddSection("Information", "left")
        l:AddLabel("UI visual segura con animaciones, tabs y selector de color.")

        local r = home:AddSection("Actions", "right")
        r:AddButton("Show Notification", function()
            window:Notify("Todo funcionando")
        end)
    end

    local playersVisual = visuals:AddSubTab("Players")
    do
        local l = playersVisual:AddSection("Preview", "left")
        l:AddToggle("Show Character Preview", false, function(v)
            if v then
                window:CreatePreviewPanel()
                if window.PreviewPanel then
                    window.PreviewPanel.Visible = true
                end
            else
                if window.PreviewPanel then
                    window.PreviewPanel.Visible = false
                end
            end
        end)

        l:AddColorPicker("Box Color", Theme.Accent, function(c)
            Theme.Accent = c
        end)

        local r = playersVisual:AddSection("Labels", "right")
        r:AddToggle("Name", false)
        r:AddSlider("Name Size", 8, 24, 12)
        r:AddDropdown("Font", {"Gotham", "Arial", "Verdana"}, "Gotham")
    end

    local localTab = player:AddSubTab("Local")
    do
        local l = localTab:AddSection("Character", "left")
        l:AddSlider("WalkSpeed", 0, 100, 16)
        l:AddSlider("JumpPower", 0, 150, 50)
    end

    local cfg = settings:AddSubTab("Menu")
    do
        local r = cfg:AddSection("Settings", "right")

        local keyMap = {
            Z = Enum.KeyCode.Z,
            X = Enum.KeyCode.X,
            C = Enum.KeyCode.C,
            V = Enum.KeyCode.V,
            RightShift = Enum.KeyCode.RightShift
        }

        r:AddDropdown("Hide Menu Key", {"Z", "X", "C", "V", "RightShift"}, "Z", function(v)
            window.HideKey = keyMap[v] or Enum.KeyCode.Z
            window:Notify("Hide key: " .. v)
        end)

        r:AddButton("Unload UI", function()
            if window.PreviewConn then
                window.PreviewConn:Disconnect()
            end
            if window.Blur then
                window.Blur:Destroy()
            end
            if window.GUI then
                window.GUI:Destroy()
            end
        end)
    end

    main:Show()
end

return Library
