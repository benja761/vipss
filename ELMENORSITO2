        do
            local left = world:AddSection("World Settings", "left")
            left:AddToggle("Ambient Enabled", false)
            left:AddColorPicker("Ambient Color", Theme.Accent)
            left:AddSlider("Brightness", 0, 10, 2)
            left:AddSlider("Clock Time", 0, 24, 14)
            left:AddToggle("Fullbright", false, function(v)
                if v then
                    Lighting.Brightness = 3
                    Lighting.GlobalShadows = false
                    Lighting.Ambient = Color3.fromRGB(200, 200, 200)
                else
                    Lighting.GlobalShadows = true
                end
            end)
            left:AddToggle("Depth Blur", false, function(v)
                local eff = Lighting:FindFirstChild("ValaryDepthBlur")
                if v then
                    if not eff then
                        eff = Instance.new("BlurEffect")
                        eff.Name = "ValaryDepthBlur"
                        eff.Size = 8
                        eff.Parent = Lighting
                    end
                else
                    if eff then
                        eff:Destroy()
                    end
                end
            end)

            local right = world:AddSection("Camera", "right")
            right:AddSlider("Field Of View", 40, 120, 70, function(v)
                self.BaseFOV = v
                local cam = workspace.CurrentCamera
                if cam then
                    if self.StretchEnabled then
                        cam.FieldOfView = v + (self.StretchAmount * 0.35)
                    else
                        cam.FieldOfView = v
                    end
                end
            end)
            right:AddToggle("Enabled Resolution", false, function(v)
                self.StretchEnabled = v
                local cam = workspace.CurrentCamera
                if cam then
                    if v then
                        cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
                    else
                        cam.FieldOfView = self.BaseFOV
                    end
                end
            end)
            right:AddSlider("Stretch Amount", 0, 40, 0, function(v)
                self.StretchAmount = v
                local cam = workspace.CurrentCamera
                if cam and self.StretchEnabled then
                    cam.FieldOfView = self.BaseFOV + (v * 0.35)
                end
            end)
        end

        local uiVisual = visualsTab:AddSubTab("UI")
        do
            local left = uiVisual:AddSection("Menu Effects", "left")
            left:AddToggle("Blur Enabled", true, function(v)
                if self.Blur then
                    self.Blur.Size = v and 4 or 0
                end
            end)
            left:AddSlider("Blur Size", 0, 20, 4, function(v)
                if self.Blur then
                    self.Blur.Size = v
                end
            end)
            left:AddToggle("Show Bottom Tabs", true, function(v)
                self.MainTabsHolder.Visible = v
                self.SubTabHolder.Visible = v and self.CurrentTab and (#self.CurrentTab.SubTabs > 0) or false
            end)
            left:AddToggle("Menu Sounds", true)
            left:AddToggle("Smooth Open", true)

            local right = uiVisual:AddSection("Theme", "right")
            right:AddColorPicker("UI Accent", Theme.Accent, function(c)
                self:SetAccent(c)
            end, true)
            right:AddDropdown("Preset", {"Blue", "Green", "Red", "White", "Orange"}, "Blue", function(v)
                if v == "Blue" then self:SetAccent(Color3.fromRGB(0, 170, 255)) end
                if v == "Green" then self:SetAccent(Color3.fromRGB(0, 255, 140)) end
                if v == "Red" then self:SetAccent(Color3.fromRGB(255, 70, 70)) end
                if v == "White" then self:SetAccent(Color3.fromRGB(230, 230, 230)) end
                if v == "Orange" then self:SetAccent(Color3.fromRGB(255, 140, 0)) end
            end)
            right:AddSlider("UI Scale Preview", 0.8, 1.3, 1)
            right:AddToggle("Rounded Theme", true)
        end

        local players = visualsTab:AddSubTab("Players")
        do
            local left = players:AddSection("ESP Visuals", "left")
            left:AddToggle("Enable Player ESP", false)
            left:AddDropdown("Box Type", {"Full Box", "Corner Box"}, "Corner Box")
            left:AddToggle("Box Outline", true)
            left:AddSlider("Box Thickness", 1, 5, 2)
            left:AddColorPicker("Box Color", Theme.Accent)
            left:AddToggle("Filled Box", false)
            left:AddSlider("Fill Transparency", 0, 1, 0.2)
            left:AddToggle("Health Bar", true)
            left:AddDropdown("Health Style", {"Left", "Right", "Bottom"}, "Left")
            left:AddToggle("Health Text", false)
            left:AddToggle("Name", true)
            left:AddSlider("Name Size", 8, 24, 13)
            left:AddToggle("Distance", false)
            left:AddSlider("Distance Size", 8, 24, 11)
            left:AddToggle("Weapon Text", false)
            left:AddSlider("Weapon Size", 8, 24, 11)

            local mid = players:AddSection("Skeleton / Tracers", "right")
            mid:AddToggle("Skeleton", false)
            mid:AddDropdown("Skeleton Type", {"Basic", "Pro"}, "Basic")
            mid:AddSlider("Skeleton Thickness", 1, 4, 1)
            mid:AddColorPicker("Skeleton Color", Theme.White)
            mid:AddToggle("Tracer", false)
            mid:AddDropdown("Tracer Origin", {"Top", "Middle", "Bottom"}, "Bottom")
            mid:AddSlider("Tracer Thickness", 1, 4, 1)
            mid:AddColorPicker("Tracer Color", Theme.Accent)
            mid:AddToggle("Head Dot", false)
            mid:AddSlider("Head Dot Size", 2, 10, 4)
            mid:AddToggle("View Direction", false)
            mid:AddSlider("View Direction Length", 5, 40, 15)

            local extra = players:AddSection("Preview / Extra", "left")
            extra:AddToggle("Show Character Preview", false, function(v)
                if v then
                    self:CreatePreviewPanel()
                    if self.PreviewPanel then
                        self.PreviewPanel.Visible = true
                    end
                else
                    if self.PreviewPanel then
                        self.PreviewPanel.Visible = false
                    end
                end
            end)
            extra:AddSlider("Preview Rotation Speed", 1, 40, 16, function(v)
                self.PreviewRotationSpeed = v
            end)
            extra:AddColorPicker("Preview Accent", Theme.Accent)
            extra:AddToggle("Show Team Color", false)
            extra:AddToggle("Show Friend Marker", false)
            extra:AddToggle("Show Visibility State", false)
        end

        -- SETTINGS
        local settingsMain = settingsTab:AddSubTab("Main")
        do
            local left = settingsMain:AddSection("Menu", "left")
            left:AddLabel("This tab keeps your menu settings/config area.")
            left:AddButton("Show Notification", function()
                self:Notify("Settings tab working")
            end)
            left:AddKeybind("Hide Key", Enum.KeyCode.Z, function(key)
                self.HideKey = key
            end)
            left:AddToggle("Notifications", true)
            left:AddToggle("Save Config Preview", false)

            local right = settingsMain:AddSection("Config", "right")
            right:AddDropdown("Config Slot", {"Default", "Legit", "Rage", "Visual"}, "Default")
            right:AddButton("Load Config", function()
                self:Notify("Load clicked")
            end)
            right:AddButton("Save Config", function()
                self:Notify("Save clicked")
            end)
            right:AddButton("Reset Config", function()
                self:Notify("Reset clicked")
            end)
        end

        local settingsTheme = settingsTab:AddSubTab("Theme")
        do
            local left = settingsTheme:AddSection("Theme Color", "left")
            left:AddColorPicker("Accent", Theme.Accent, function(c)
                self:SetAccent(c)
            end, true)
            left:AddDropdown("Preset", {"Blue", "Green", "Red", "White", "Orange"}, "Blue", function(v)
                if v == "Blue" then self:SetAccent(Color3.fromRGB(0, 170, 255)) end
                if v == "Green" then self:SetAccent(Color3.fromRGB(0, 255, 140)) end
                if v == "Red" then self:SetAccent(Color3.fromRGB(255, 70, 70)) end
                if v == "White" then self:SetAccent(Color3.fromRGB(230, 230, 230)) end
                if v == "Orange" then self:SetAccent(Color3.fromRGB(255, 140, 0)) end
            end)

            local right = settingsTheme:AddSection("Misc", "right")
            right:AddToggle("Intro Sound", true)
            right:AddToggle("Button Sound", true)
            right:AddSlider("Animation Speed", 0.05, 1, 0.18)
        end

        combatTab:Show()
        self:ApplySearch("")
        self:SetAccent(Theme.Accent)
        self:UpdateFOVCircle()
    end

    RunService.RenderStepped:Connect(function()
        self:UpdateFOVCircle()
    end)

    self:BuildDemo()
    return self
end

return Library
