            ZIndex = 3,
        })
    end
end

function Library:UpdateCombatOverlay()
    if not self.CombatCircle or not self.CombatCircle.Parent then
        return
    end
    
    self.CombatCircle.Visible = self.CombatState.CircleVisible
    
    if self.CombatState.CircleVisible then
        local size = self.CombatState.CircleRadius * 2
        self.CombatCircle.Size = UDim2.new(0, size, 0, size)
        self.CombatCircle.Position = UDim2.new(0.5, -size/2, 0.5, -size/2)
        
        local stroke = self.CombatCircle:FindFirstChildWhichIsA("UIStroke")
        if stroke then
            stroke.Color = self.CombatState.CircleColor
            stroke.Thickness = self.CombatState.CircleThickness
            stroke.Transparency = self.CombatState.CircleTransparency
        end
    end
    
    if self.Crosshair then
        self.Crosshair.Visible = self.CombatState.CrosshairVisible
        
        if self.CombatState.CrosshairVisible then
            local size = self.CombatState.CrosshairSize
            local gap = self.CombatState.CrosshairGap
            
            self.Crosshair.Size = UDim2.new(0, size, 0, size)
            self.Crosshair.Position = UDim2.new(0.5, -size/2, 0.5, -size/2)
            
            local h1 = self.Crosshair:FindFirstChildOfClass("Frame")
            local h2 = self.Crosshair:FindFirstChildWhichIsA("Frame")
            
            if h1 and h2 then
                h1.BackgroundColor3 = self.CombatState.CrosshairColor
                h2.BackgroundColor3 = self.CombatState.CrosshairColor
            end
        end
    end
end

function Library:Run()
    -- Main loop for updates
    task.spawn(function()
        while self.GUI and self.GUI.Parent do
            self:UpdateCombatOverlay()
            
            if self.PreviewState.Visible then
                self:CreateESPPreview()
            end
            
            task.wait(0.1)
        end
    end)
    
    return self
end

-- Return the Library object
return Library
