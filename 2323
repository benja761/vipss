                continue
            end
            
            -- Visibility check
            if Aimbot.VisibleCheck and not IsVisible(player.Character, player.Character.HumanoidRootPart) then
                continue
            end
            
            local hrp = player.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local distance = (hrp.Position - Camera.CFrame.Position).Magnitude
                
                -- FOV check
                local mouseDistance = (Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if mouseDistance <= Aimbot.FOV then
                    if distance < closestDistance then
                        closestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

local function AimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild(Aimbot.TargetPart) then
        CurrentTarget = nil
        return
    end
    
    CurrentTarget = target
    local targetPart = target.Character[Aimbot.TargetPart]
    local camera = Workspace.CurrentCamera
    
    -- Calculate smooth aim
    local targetPosition = targetPart.Position
    if Aimbot.Prediction > 0 then
        local velocity = targetPart.Velocity
        targetPosition = targetPosition + (velocity * Aimbot.Prediction)
    end
    
    local currentCFrame = camera.CFrame
    local targetCFrame = CFrame.lookAt(currentCFrame.Position, targetPosition)
    
    -- Apply smoothing
    local smoothFactor = math.clamp(Aimbot.Smooth, 1, 20)
    local smoothedCFrame = currentCFrame:Lerp(targetCFrame, 1/smoothFactor)
    
    camera.CFrame = smoothedCFrame
end

