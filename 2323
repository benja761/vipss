    function self:CreatePreviewPanel()
        if self.PreviewPanel then
            return
        end
        
        local previewPanel = Create("Frame", {
            Parent = self.GUI,
            Position = UDim2.new(0.5, -80, 0.5, -60),
            Size = UDim2.new(0, 160, 0, 120),
            BackgroundColor3 = Theme.Element,
