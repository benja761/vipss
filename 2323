            ZIndex = 10,
        })
        
        self.PreviewPanel = previewPanel
        self.PreviewViewport = viewport
        
        cloneCharacter(viewport)
        
        if self.CharacterAddedConn then
            self.CharacterAddedConn:Disconnect()
        end
        
        self.CharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.8)
            if self.PreviewState.Visible and self.PreviewViewport and self.PreviewViewport.Parent then
                cloneCharacter(self.PreviewViewport)
                self:UpdatePreviewESP()
            end
        end)
        
        if self.PreviewConn then
            self.PreviewConn:Disconnect()
        end
        
        self.PreviewConn = RunService.RenderStepped:Connect(function()
            if self.PreviewViewport and self.PreviewViewport.CurrentCamera then
                local cam = self.PreviewViewport.CurrentCamera
                if cam then
                    local cf = cam.CFrame
                    cam.CFrame = cf * CFrame.fromEulerAnglesXYZ(0, math.rad(self.PreviewRotationSpeed * 0.5), 0)
                end
            end
        end)
        
        if self.PreviewState.Visible then
            previewPanel.Visible = true
        else
            previewPanel.Visible = false
        end
    end
    
