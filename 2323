    function self:ApplyVisualPreset(name)
        if name == "Default" then
            self:ApplyBrightness(2)
            self:ApplyClockTime(14)
            self:ApplyFogEnd(100000)
            self:ApplyExposure(0)
            Lighting.ColorShift_Top = Color3.new(0,0,0)
            Lighting.ColorShift_Bottom = Color3.new(0,0,0)
        elseif name == "Night" then
            self:ApplyBrightness(1)
            self:ApplyClockTime(1)
            self:ApplyFogEnd(500)
            self:ApplyExposure(-0.2)
            Lighting.ColorShift_Top = Color3.fromRGB(0, 20, 50)
            Lighting.ColorShift_Bottom = Color3.fromRGB(0, 0, 20)
        elseif name == "Warm" then
            self:ApplyBrightness(2.5)
            self:ApplyClockTime(17)
            self:ApplyFogEnd(3000)
            self:ApplyExposure(0.15)
            Lighting.ColorShift_Top = Color3.fromRGB(40, 18, 0)
            Lighting.ColorShift_Bottom = Color3.fromRGB(20, 10, 0)
        elseif name == "Cold" then
            self:ApplyBrightness(2)
            self:ApplyClockTime(11)
            self:ApplyFogEnd(3000)
            self:ApplyExposure(0.05)
            Lighting.ColorShift_Top = Color3.fromRGB(0, 20, 40)
            Lighting.ColorShift_Bottom = Color3.fromRGB(0, 10, 25)
        elseif name == "Studio" then
            self:ApplyBrightness(3)
            self:ApplyClockTime(14)
            self:ApplyFogEnd(100000)
            self:ApplyExposure(0.2)
            Lighting.ColorShift_Top = Color3.fromRGB(8, 8, 8)
            Lighting.ColorShift_Bottom = Color3.fromRGB(0, 0, 0)
        end
    end
    
