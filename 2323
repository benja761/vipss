local function getSafeCharacter()
    local char = LocalPlayer.Character
    if char and char.Parent then
        return char
    end
    
    local ok, result = pcall(function()
        return LocalPlayer.CharacterAdded:Wait()
    end)
    
    if ok and result and result.Parent then
        return result
    end
    
    return nil
end

local function cloneCharacter(viewport)
    if not viewport or not viewport.Parent then
        return nil
    end
    
    viewport:ClearAllChildren()
    
    local cam = Instance.new("Camera")
    cam.Parent = viewport
    viewport.CurrentCamera = cam
    
    local char = getSafeCharacter()
    if not char then
        return nil
    end
    
    local ok, clone = pcall(function()
        return char:Clone()
    end)
    
    if not ok or not clone then
        return nil
    end
    
    local okDesc, descendants = pcall(function()
        return clone:GetDescendants()
    end)
    
    if okDesc and descendants then
        for _, v in ipairs(descendants) do
            if v:IsA("BaseScript") or v:IsA("LocalScript") or v:IsA("ModuleScript") then
                v:Destroy()
            elseif v:IsA("Humanoid") then
                v.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                v.AutoRotate = false
            elseif v:IsA("BasePart") then
                v.Anchored = true
                v.CanCollide = false
            end
        end
    end
    
    clone.Parent = viewport
    
    local primary = clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChildWhichIsA("BasePart")
    if primary then
        clone.PrimaryPart = primary
        pcall(function()
            clone:PivotTo(CFrame.new(0, -0.8, 0))
        end)
    end
    
    cam.CFrame = CFrame.new(Vector3.new(0, 1.5, 5.1), Vector3.new(0, 1.2, 0))
    
    local light = Instance.new("PointLight")
    light.Range = 24
    light.Brightness = 1.8
    light.Parent = cam
    
    return clone
end

