    -- Build working ESP/Aimbot tabs
    function self:BuildWorkingTabs()
        -- ESP Tab
        local espTab = self:AddTab("ESP")
        local espMain = espTab:AddSubTab("Main")
        
        local espLeft = espMain:AddSection("ESP Settings", "left")
        espLeft:AddToggle("ESP Enabled", false, function(state)
            ESP.Enabled = state
            ToggleESP(state)
        end)
        
        espLeft:AddToggle("Box ESP", true, function(state)
            ESP.Boxes = state
        end)
        
        espLeft:AddToggle("Show Names", true, function(state)
            ESP.Names = state
        end)
        
        espLeft:AddToggle("Show Distance", true, function(state)
            ESP.Distances = state
        end)
        
        espLeft:AddToggle("Show Health", true, function(state)
            ESP.Health = state
        end)
        
        espLeft:AddToggle("Team Check", false, function(state)
            ESP.TeamCheck = state
        end)
        
        espLeft:AddToggle("Friend Check", false, function(state)
            ESP.FriendCheck = state
        end)
        
        espLeft:AddToggle("Visibility Check", false, function(state)
            ESP.VisibleCheck = state
        end)
        
