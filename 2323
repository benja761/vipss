                            colorFrame:Destroy()
                        end)
                        
                        UIS.InputBegan:Connect(function(input, processed)
                            if processed then
                                return
                            end
                            if input.KeyCode == Enum.KeyCode.Return then
                                local hex = valueEntry.Text
                                if hex:match("^#[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]$") then
                                    local r = tonumber(hex:sub(2, 3), 16) or 255
                                    local g = tonumber(hex:sub(4, 5), 16) or 255
                                    local b = tonumber(hex:sub(6, 7), 16) or 255
                                    local col = Color3.fromRGB(r, g, b)
                                    currentHue, currentSat, currentVal = col:ToHSV()
                                    updateColor()
                                end
                            end
                        end)
                        
                        return colorFrame
