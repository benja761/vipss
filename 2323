                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                hueDragging = false
                            end
                        end)
                        
                        hueSlider.InputChanged:Connect(function(input)
                            if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                                local x = (input.Position.X - hueSlider.AbsolutePosition.X) / hueSlider.AbsoluteSize.X
                                currentHue = math.clamp(x, 0, 1)
                                hueKnob.Position = UDim2.new(currentHue, 0, 0.5, 0)
                                updateColor()
                            end
                        end)
                        
                        colorSelect.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                colorDragging = true
                            end
                        end)
                        
                        colorSelect.InputEnded:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                colorDragging = false
                            end
                        end)
                        
                        colorSelect.InputChanged:Connect(function(input)
                            if colorDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                                local x = (input.Position.X - colorSelect.AbsolutePosition.X) / colorSelect.AbsoluteSize.X
                                local y = (input.Position.Y - colorSelect.AbsolutePosition.Y) / colorSelect.AbsoluteSize.Y
                                currentSat = math.clamp(x, 0, 1)
                                currentVal = math.clamp(1 - y, 0, 1)
                                updateColor()
                            end
                        end)
                        
                        confirm.MouseButton1Click:Connect(function()
                            self.ParentWindow:PlayMenuSound("pop")
                            colorFrame:Destroy()
                        end)
                        
                        cancel.MouseButton1Click:Connect(function()
