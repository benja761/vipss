function Library:AddSlider(name, flag, min, max, default, decimals, suffix, callback, section)
    local slider = Create("Frame", {
        Parent = section,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 52),
    })
    
    local label = Create("TextLabel", {
        Parent = slider,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 20),
        Font = Enum.Font.Gotham,
        TextSize = 13,
        Text = name,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local valueLabel = Create("TextLabel", {
        Parent = slider,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -60, 0, 0),
        Size = UDim2.new(0, 60, 0, 20),
        Font = Enum.Font.Gotham,
        TextSize = 13,
        Text = tostring(default) .. (suffix or ""),
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    local track = Create("Frame", {
        Parent = slider,
        BackgroundColor3 = Theme.Element,
        Position = UDim2.new(0, 0, 0, 28),
        Size = UDim2.new(1, 0, 0, 8),
    })
    Corner(track, 99)
    Stroke(track, Theme.Border, 1)
    
    local fill = Create("Frame", {
        Parent = track,
        BackgroundColor3 = Theme.Accent,
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
    })
    Corner(fill, 99)
    
    local dot = Create("Frame", {
        Parent = track,
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Position = UDim2.new((default - min) / (max - min), -6, 0.5, -6),
        Size = UDim2.new(0, 12, 0, 12),
        ZIndex = 2,
    })
    Corner(dot, 99)
    
    local dragging = false
    
    local function updateSlider(x)
        local relX = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = min + (max - min) * relX
        
        if decimals and decimals > 0 then
            value = math.floor(value * (10 ^ decimals)) / (10 ^ decimals)
        else
            value = math.floor(value)
        end
        
        self.Flags[flag] = value
        
        local percentage = (value - min) / (max - min)
        Tween(fill, 0.12, {Size = UDim2.new(percentage, 0, 1, 0)})
        Tween(dot, 0.12, {Position = UDim2.new(percentage, -6, 0.5, -6)})
        
        valueLabel.Text = tostring(value) .. (suffix or "")
        
        if callback then
            callback(value)
        end
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)
    
    track.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            if self._MenuSounds then
                playPop()
            end
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)
    
    setHover(track, Theme.Element, Theme.ElementHover)
    
    self.Flags[flag] = default
    return track
end

