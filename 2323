    autofarmTeleportSection:AddButton("Teleport to Spawn", function()
        self:Notify("Teleporting to Spawn")
    end)
    
    autofarmTeleportSection:AddButton("Teleport to Market", function()
        self:Notify("Teleporting to Market")
    end)
    
    autofarmTeleportSection:AddButton("Teleport to Boss", function()
        self:Notify("Teleporting to Boss")
    end)
    
    local autofarmAutoSection = autofarmAuto:AddSection("Auto Actions", "left")
    
    autofarmAutoSection:AddToggle("Auto Rejoin", false)
    
    autofarmAutoSection:AddToggle("Anti AFK", true)
    
    autofarmAutoSection:AddToggle("Auto Equip Best", false)
    
    if #self.Tabs > 0 then
        self.Tabs[1].SubTabs[1]:Show()
    end
    
    if self._SmoothOpen then
        main.Size = UDim2.new(0, 760, 0, 96)
        Tween(main, 0.22, {
            Size = UDim2.new(0, 760, 0, 500)
        })
    end
    
    if self.Notify then
        task.delay(0.5, function()
            self:Notify("Valary Style UI Loaded | " .. self.Title)
        end)
    end
    
    self:PlayMenuSound("open")
    
    return self
end

return Library
