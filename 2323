    function self:UpdateCombatOverlay()
        self:EnsureCombatOverlay()
        
        if self.CombatCircle then
            local d = math.max(10, self.CombatState.CircleRadius * 2)
            self.CombatCircle.Visible = self.CombatState.CircleVisible
            self.CombatCircle.Size = UDim2.new(0, d, 0, d)
        end
        
        if self.CombatCircleStroke then
            self.CombatCircleStroke.Color = self.CombatState.CircleColor
            self.CombatCircleStroke.Thickness = self.CombatState.CircleThickness
            self.CombatCircleStroke.Transparency = self.CombatState.CircleTransparency
        end
        
        if self.CrosshairFrame and self.CrosshairLines then
            self.CrosshairFrame.Visible = self.CombatState.CrosshairVisible
            local size = self.CombatState.CrosshairSize
            local gap = self.CombatState.CrosshairGap
            local thick = self.CombatState.CrosshairThickness
            local color = self.CombatState.CrosshairColor
            
            local topLine = self.CrosshairLines[1]
            topLine.Size = UDim2.new(0, thick, 0, size)
            topLine.Position = UDim2.new(0.5, -thick/2, 0.5, -(gap + size))
            topLine.BackgroundColor3 = color
            
            local bottomLine = self.CrosshairLines[2]
            bottomLine.Size = UDim2.new(0, thick, 0, size)
            bottomLine.Position = UDim2.new(0.5, -thick/2, 0.5, gap)
            bottomLine.BackgroundColor3 = color
            
            local leftLine = self.CrosshairLines[3]
            leftLine.Size = UDim2.new(0, size, 0, thick)
            leftLine.Position = UDim2.new(0.5, -(gap + size), 0.5, -thick/2)
            leftLine.BackgroundColor3 = color
            
            local rightLine = self.CrosshairLines[4]
            rightLine.Size = UDim2.new(0, size, 0, thick)
            rightLine.Position = UDim2.new(0.5, gap, 0.5, -thick/2)
            rightLine.BackgroundColor3 = color
        end
        
        if self.HitMarkerFrame and self.HitMarkerLines then
            self.HitMarkerFrame.Visible = self.CombatState.HitMarkerVisible
            local s = self.CombatState.HitMarkerSize
            for _, line in ipairs(self.HitMarkerLines) do
                line.Size = UDim2.new(0, 2, 0, s)
                line.Position = UDim2.new(0.5, -1, 0.5, -s/2)
            end
        end
        
        if self.CombatStatus then
            self.CombatStatus.Visible = self.CombatState.StatusTextVisible
            self.CombatStatus.Text = tostring(self.CombatState.StatusText)
            self.CombatStatus.TextColor3 = self.CombatState.StatusTextColor
        end
        
        if self.PulseFrame then
            self.PulseFrame.Visible = self.CombatState.PulseVisible
            self.PulseFrame.Size = UDim2.new(0, self.CombatState.PulseSize, 0, self.CombatState.PulseSize)
        end
    end
    
