                Corner(optionBtn, 4)
                
                optionBtn.MouseButton1Click:Connect(function()
                    button.Text = option
                    self.Flags[flag] = option
                    if callback then
                        callback(option)
                    end
                    toggleDropdown()
                    if self._MenuSounds then
                        playPop()
                    end
                end)
                
                setHover(optionBtn, Theme.Panel2, Theme.Element)
            end
        else
            if dropdownList then
                dropdownList:Destroy()
