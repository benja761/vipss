    function self:SetAccent(color)
        Theme.Accent = color
        Theme.AccentDark = color:Lerp(Color3.new(0, 0, 0), 0.35)
        
        if self.BrandAccent then
            self.BrandAccent.TextColor3 = color
        end
        
        for _, obj in ipairs(self.AccentObjects or {}) do
            if obj and obj.Parent then
                local mode = obj:GetAttribute("AccentMode")
                if mode == "bg" then
                    obj.BackgroundColor3 = color
                elseif mode == "stroke" then
                    obj.Color = color
                elseif mode == "text" then
                    obj.TextColor3 = color
                end
            end
        end
        
        for _, toggleData in ipairs(self.LiveToggles or {}) do
            if toggleData and toggleData.Render and toggleData.Switch and toggleData.Switch.Parent then
                toggleData.Render()
            end
        end
        
        self:UpdatePreviewESP()
        self:UpdateCombatOverlay()
    end
    
    function self:ApplyBrightness(v)
        Lighting.Brightness = tonumber(v) or 2
    end
    
    function self:ApplyClockTime(v)
        Lighting.ClockTime = tonumber(v) or 14
    end
    
    function self:ApplyAmbientEnabled(enabled, color)
        self._AmbientEnabled = enabled and true or false
        if self._AmbientEnabled then
            local c = color or self._AmbientColor or Theme.Accent
            Lighting.Ambient = c
            Lighting.OutdoorAmbient = c
        else
            Lighting.Ambient = self._OriginalLighting.Ambient
            Lighting.OutdoorAmbient = self._OriginalLighting.OutdoorAmbient
        end
    end
    
    function self:ApplyAmbientColor(color)
        self._AmbientColor = color
        if self._AmbientEnabled then
            Lighting.Ambient = color
            Lighting.OutdoorAmbient = color
        end
    end
    
    function self:ApplyFullbright(state)
        if state then
            Lighting.Brightness = 3
            Lighting.GlobalShadows = false
            Lighting.Ambient = Color3.fromRGB(200, 200, 200)
            Lighting.OutdoorAmbient = Color3.fromRGB(200, 200, 200)
        else
            Lighting.GlobalShadows = self._OriginalLighting.GlobalShadows
            Lighting.Brightness = self._OriginalLighting.Brightness
            if self._AmbientEnabled then
                Lighting.Ambient = self._AmbientColor
                Lighting.OutdoorAmbient = self._AmbientColor
            else
                Lighting.Ambient = self._OriginalLighting.Ambient
                Lighting.OutdoorAmbient = self._OriginalLighting.OutdoorAmbient
            end
        end
    end
    
    function self:ApplyFOV(value)
        self.BaseFOV = tonumber(value) or 70
        local cam = workspace.CurrentCamera
        if cam then
            if self.StretchEnabled then
                cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
            else
                cam.FieldOfView = self.BaseFOV
            end
        end
    end
    
    function self:ApplyStretchEnabled(state)
        self.StretchEnabled = state and true or false
        local cam = workspace.CurrentCamera
        if cam then
            if self.StretchEnabled then
                cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
            else
                cam.FieldOfView = self.BaseFOV
            end
        end
    end
    
    function self:ApplyStretchAmount(value)
        self.StretchAmount = tonumber(value) or 0
        local cam = workspace.CurrentCamera
        if cam and self.StretchEnabled then
            cam.FieldOfView = self.BaseFOV + (self.StretchAmount * 0.35)
        end
