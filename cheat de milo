local function CreateLine()
    local l = Drawing.new("Line")
    l.Thickness = 2
    l.Visible = false
    l.Transparency = 1
    return l
end

local function ClearAllVisuals(plr)
    if SkeletonDrawings[plr] then
        for _, obj in pairs(SkeletonDrawings[plr]) do obj.Visible = false; obj:Remove() end
        SkeletonDrawings[plr] = nil
    end
    if CornerDrawings[plr] then
        for _, obj in pairs(CornerDrawings[plr]) do obj.Visible = false; obj:Remove() end
        CornerDrawings[plr] = nil
    end
end

