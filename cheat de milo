-- ================= LOOP CORE FINAL (CON CORRECCIÓN DE BUGS) =================
RunService.RenderStepped:Connect(function()
    local rainbow = Color3.fromHSV(tick() % 5 / 5, 0.8, 1)
    FOVCircle.Radius = FOVSize
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Visible = InterfaceVisible
    FOVCircle.Color = FOVRainbow and rainbow or MoradoIntenso

    for _, p in pairs(Players:GetPlayers()) do
        local char = p.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if p == LocalPlayer or not char or not hum or hum.Health <= 0 or not hrp then
            ClearAllVisuals(p)
        else
            -- LÓGICA CORNER ESP
            if CornerESP_Activo and InterfaceVisible then
                if not CornerDrawings[p] then
                    CornerDrawings[p] = {}
                    for i = 1, 8 do table.insert(CornerDrawings[p], CreateLine()) end
                end
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                local lines = CornerDrawings[p]
                if onScreen then
                    local top = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.8, 0))
                    local bottom = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, -4.2, 0))
                    local h = math.abs(top.Y - bottom.Y)
                    local w = h * 0.6
                    local x, y = pos.X - w/2, pos.Y - h/2
                    local len = w/4
                    for _, l in pairs(lines) do l.Visible = true; l.Color = CornerColor end
                    lines[1].From, lines[1].To = Vector2.new(x, y), Vector2.new(x + len, y)
                    lines[2].From, lines[2].To = Vector2.new(x, y), Vector2.new(x, y + len)
                    lines[3].From, lines[3].To = Vector2.new(x + w, y), Vector2.new(x + w - len, y)
                    lines[4].From, lines[4].To = Vector2.new(x + w, y), Vector2.new(x + w, y + len)
                    lines[5].From, lines[5].To = Vector2.new(x, y + h), Vector2.new(x + len, y + h)
                    lines[6].From, lines[6].To = Vector2.new(x, y + h), Vector2.new(x, y + h - len)
                    lines[7].From, lines[7].To = Vector2.new(x + w, y + h), Vector2.new(x + w - len, y + h)
                    lines[8].From, lines[8].To = Vector2.new(x + w, y + h), Vector2.new(x + w, y + h - len)
                else for _, l in pairs(lines) do l.Visible = false end end
            else if CornerDrawings[p] then for _, l in pairs(CornerDrawings[p]) do l.Visible = false end end end

            -- LÓGICA SKELETON ESTRELLA
            if SkeletonEnabled and InterfaceVisible then
                if not SkeletonDrawings[p] then
                    SkeletonDrawings[p] = {H2T=CreateLine(), T2LA=CreateLine(), T2RA=CreateLine(), T2LL=CreateLine(), T2RL=CreateLine()}
                end
                local sk = SkeletonDrawings[p]
                local function getV2(name)
                    local part = char:FindFirstChild(name)
                    if part then
                        local vPos, vis = Camera:WorldToViewportPoint(part.Position)
                        return vis and Vector2.new(vPos.X, vPos.Y) or nil
                    end return nil
                end
                local h, t = getV2("Head"), getV2("UpperTorso") or getV2("Torso")
                if h and t then
                    sk.H2T.From, sk.H2T.To, sk.H2T.Visible = h, t, true
                    local la, ra = getV2("LeftUpperArm") or getV2("Left Arm"), getV2("RightUpperArm") or getV2("Right Arm")
                    local ll, rl = getV2("LeftUpperLeg") or getV2("Left Leg"), getV2("RightUpperLeg") or getV2("Right Leg")
                    if la then sk.T2LA.From, sk.T2LA.To, sk.T2LA.Visible = t, la, true else sk.T2LA.Visible = false end
                    if ra then sk.T2RA.From, sk.T2RA.To, sk.T2RA.Visible = t, ra, true else sk.T2RA.Visible = false end
                    if ll then sk.T2LL.From, sk.T2LL.To, sk.T2LL.Visible = t, ll, true else sk.T2LL.Visible = false end
                    if rl then sk.T2RL.From, sk.T2RL.To, sk.T2RL.Visible = t, rl, true else sk.T2RL.Visible = false end
                    for _, l in pairs(sk) do l.Color = SkeletonColor end
                else for _, l in pairs(sk) do l.Visible = false end end
            else if SkeletonDrawings[p] then for _, l in pairs(SkeletonDrawings[p]) do l.Visible = false end end end
        end
    end

    -- AIMBOT LOGIC
    if AimbotMaster and AimbotActive then
        local target, short = nil, FOVSize
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                local pos, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - FOVCircle.Position).Magnitude
                    if mag < short then target = v.Character.Head; short = mag end
                end
            end
        end
        if target then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), AimSmoothing) end
    end
end)

UIS.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.P then InterfaceVisible = not InterfaceVisible; Window:Toggle()
    elseif i.KeyCode == Enum.KeyCode.Z then AimbotActive = not AimbotActive
        Rayfield:Notify({Title = "Aimbot", Content = AimbotActive and "ON" or "OFF", Duration = 2})
    end
end)
